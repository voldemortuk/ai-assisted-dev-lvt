/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: STAT STATEMENT (I1)
   ═══════════════════════════════════════════════════════════════ */
.stat-slide {
  background: #1c1917;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 160px;
}

.stat-slide::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48px;
  height: 3px;
  background: #c2410c;
  border-radius: 0 0 3px 3px;
}

.stat-slide .statement {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 52px;
  font-weight: 400;
  line-height: 1.2;
  color: #ffffff;
  text-align: center;
  letter-spacing: -0.02em;
  margin-bottom: 32px;
}

.stat-slide .statement + .statement {
  margin-top: 24px;
  margin-bottom: 48px;
}

.stat-slide .stat { color: #c2410c; }

.stat-slide .attribution {
  font-size: 15px;
  font-weight: 400;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.04em;
  text-align: center;
}

.stat-slide .logo-block {
  position: absolute;
  bottom: 16px;
  left: 60px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  opacity: 0.4;
}

.stat-slide .logo-block img { height: 16px; width: auto; display: block; }
.stat-slide .logo-block .confidential { color: rgba(255,255,255,0.9); }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: AIQ FRAMEWORK (I6)
   ═══════════════════════════════════════════════════════════════ */
/* .aiq-slide extends .content-slide — no padding or background overrides here */
.aiq-slide { }

/* ── AIQ™ vertical arrow ── */
.aiq-arrow-wrap {
  position: absolute;
  left: 12px; top: 162px; bottom: 110px;
  width: 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.aiq-arrowhead { font-size: 11px; color: #c2410c; line-height: 1; margin-bottom: 3px; flex-shrink: 0; }
.aiq-shaft { flex: 1; position: relative; display: flex; align-items: center; justify-content: center; width: 100%; }
.aiq-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; background: #c2410c; transform: translateX(-50%); border-radius: 1px; }
.aiq-label { writing-mode: vertical-rl; transform: rotate(180deg); font-size: 11px; font-weight: 700; color: #c2410c; letter-spacing: 0.12em; text-transform: uppercase; position: relative; z-index: 1; background: #fffbf7; padding: 6px 0; white-space: nowrap; }
.aiq-label sup { font-size: 7px; vertical-align: super; }

/* ── Zone bar ── */
.aiq-zone-bar { display: flex; gap: 16px; width: 1088px; margin-left: 40px; margin-top: 10px; margin-bottom: 10px; flex-shrink: 0; }
.aiq-zone { height: 48px; border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; color: #ffffff; }
.aiq-zone-op { width: 352px; flex-shrink: 0; background: #c2410c; }
.aiq-zone-ai { flex: 1; background: #1c1917; }
.aiq-zone-title { font-size: 15px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
.aiq-zone-sub   { font-size: 14px; font-weight: 400; opacity: 0.82; }

/* ── Diagram area ── */
.aiq-diagram { flex: 1; position: relative; min-height: 0; }
.aiq-baseline { position: absolute; left: 40px; right: 40px; bottom: 0; height: 2px; background: #e7dfd7; border-radius: 1px; }
.aiq-zone-divider { position: absolute; left: 400px; top: 0; bottom: 0; width: 2px; background: #e7dfd7; border-radius: 1px; }

/* Step lines */
.step-line { position: absolute; width: 2px; bottom: 0; border-radius: 2px 2px 0 0; }
.step-line-op { background: #c2410c; }
.step-line-ai { background: #1c1917; }
.sl1 { left: 124px;  height: 44px;  }
.sl2 { left: 308px;  height: 82px;  }
.sl3 { left: 492px;  height: 122px; }
.sl4 { left: 676px;  height: 168px; }
.sl5 { left: 860px;  height: 220px; }
.sl6 { left: 1044px; height: 278px; }

/* Tooltip boxes */
.step-tooltip { position: absolute; width: 168px; background: #f5f0eb; border-radius: 8px; padding: 10px 12px; border-top: 3px solid transparent; }
.tt-op { border-top-color: #c2410c; }
.tt-ai { border-top-color: #1c1917; }
.tt1 { left: 40px;  bottom: 54px;  }
.tt2 { left: 224px; bottom: 92px;  }
.tt3 { left: 408px; bottom: 132px; }
.tt4 { left: 592px; bottom: 178px; }
.tt5 { left: 776px; bottom: 230px; }
.tt6 { left: 960px; bottom: 288px; }
.tt-header { display: flex; align-items: center; gap: 5px; margin-bottom: 5px; }
.tt-num { width: 16px; height: 16px; border-radius: 50%; font-size: 9px; font-weight: 700; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.tt-num-op { background: #c2410c; }
.tt-num-ai { background: #1c1917; }
.tt-name { font-size: 13px; font-weight: 700; color: #1c1917; line-height: 1.2; }
/* tt-bullet: 12px — justified exception, 168px card width constraint */
.tt-bullet { font-size: 12px; color: #78716c; line-height: 1.35; padding-left: 10px; position: relative; margin-bottom: 3px; }
.tt-bullet::before { content: '·'; position: absolute; left: 2px; font-size: 16px; line-height: 0.85; color: #a8a29e; }

/* Takeaway margin */
.aiq-slide .takeaway-box { margin: 0 0 16px 0; }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: AIQ SPIDER (I6-aiq-spider)
   ═══════════════════════════════════════════════════════════════ */
.aqs-slide {
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  padding: 44px 60px 0;
}

.aqs-header  { margin-bottom: 16px; flex-shrink: 0; }
.aqs-body    { flex: 1; display: flex; gap: 36px; min-height: 0; }

/* Left column */
.aqs-left  { flex: 1; display: flex; flex-direction: column; gap: 8px; }

/* Zone group headers — match I6 aiq_framework zone style */
.aqs-group       { height: 48px; border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; padding: 0 12px; }
.aqs-group-op    { background: #c2410c; }
.aqs-group-ai    { background: #1c1917; }
.aqs-group-title { font-size: 15px; font-weight: 700; color: #fff; letter-spacing: 0.1em; text-transform: uppercase; }
.aqs-group-sub   { font-size: 14px; font-weight: 400; color: #fff; opacity: 0.82; }

/* 2-col card grid */
.aqs-cards    { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.aqs-cards-op { flex: 1; align-content: stretch; }
.aqs-cards-ai { flex: 2; align-content: stretch; }
.aqs-card     { padding: 10px 12px; border-radius: 6px; background: #faf5f0; border-left: 3px solid transparent; }
.aqs-card-op  { border-left-color: #c2410c; }
.aqs-card-ai  { border-left-color: #1c1917; }
.aqs-card-name { font-size: 15px; font-weight: 700; color: #1c1917; line-height: 1.2; margin: 0 0 3px; }
.aqs-card-desc { font-size: 12px; color: #78716c; line-height: 1.35; margin: 0; }

/* Right column — spider chart */
.aqs-right        { width: 360px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; }
.aqs-spider-label { font-size: 13px; font-weight: 700; color: #a8a29e; text-transform: uppercase; letter-spacing: 0.12em; }
.aqs-spider-svg   { width: 100%; max-width: 340px; overflow: visible; }
.aqs-data-poly    { fill: rgba(194,65,12,0.15); stroke: #c2410c; stroke-width: 2; }
.aqs-axis-label   { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; fill: #1c1917; }
.aqs-spider-note  { font-size: 12px; color: #a8a29e; display: flex; align-items: center; gap: 6px; }
.aqs-spider-note-dot { width: 10px; height: 10px; border-radius: 50%; background: #c2410c; opacity: 0.5; flex-shrink: 0; }

/* Bottom bar — uses shared .bottom-bar absolute position */

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: LEADERSHIP BLUEPRINT (I7)
   ═══════════════════════════════════════════════════════════════ */
/* .blueprint-slide extends .content-slide — no padding or background overrides here */
.blueprint-slide { }

.blueprint-slide .headline { margin-bottom: 8px; }

.sub-headline {
  font-size: 14px;
  font-weight: 500;
  color: #78716c;
  text-align: center;
  line-height: 1.55;
  padding-bottom: 12px;
  border-bottom: 1.5px solid #e7dfd7;
  margin-bottom: 14px;
  flex-shrink: 0;
}

/* Bookends */
.bookends { display: flex; align-items: stretch; gap: 0; flex-shrink: 0; margin-bottom: 12px; }
.bookend { flex: 1; background: #1c1917; border-radius: 14px; padding: 18px 24px; }
.bookend-name { font-family: 'DM Serif Display', Georgia, serif; font-size: 20px; color: #ffffff; margin-bottom: 5px; line-height: 1.2; }
.bookend-desc { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.5; }
.bookend-mid { flex: 1; background: #f5f0eb; border: 1.5px solid #e7dfd7; border-radius: 14px; padding: 18px 24px; display: flex; flex-direction: column; justify-content: center; text-align: center; }
.bookend-mid-name { font-family: 'DM Serif Display', Georgia, serif; font-size: 20px; color: #1c1917; margin-bottom: 5px; line-height: 1.2; }
.bookend-mid-desc { font-size: 13px; color: #78716c; line-height: 1.5; }
.bookend-arrow { display: flex; align-items: center; justify-content: center; width: 36px; flex-shrink: 0; font-size: 16px; color: #a8a29e; }

/* Module separator */
.modules-sep { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-shrink: 0; }
.dash-line { flex: 1; border-top: 1.5px dashed #d6cfc8; }
.sep-pill { background: #c2410c; color: #ffffff; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 16px; border-radius: 100px; white-space: nowrap; }

/* Module grid */
.modules-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; flex: 1; min-height: 0; margin-bottom: 14px; }
.modules-col { display: flex; flex-direction: column; }
.col-label { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; text-align: center; padding: 7px 0; border-radius: 6px; margin-bottom: 12px; flex-shrink: 0; }
.label-understand { color: #1c1917; background: rgba(28,25,23,0.07); }
.label-apply      { color: #c2410c; background: rgba(194,65,12,0.08); }
.label-change     { color: #062F7E; background: rgba(6,47,126,0.08);  }
/* All-functions aliases — same colours */
.label-amplify    { color: #1c1917; background: rgba(28,25,23,0.07); }
.label-agentic    { color: #c2410c; background: rgba(194,65,12,0.08); }
.label-accelerate { color: #062F7E; background: rgba(6,47,126,0.08);  }
.mod-card { flex: 1; background: #ffffff; border: 1px solid #ffedd5; border-radius: 12px; padding: 16px 20px; display: flex; flex-direction: column; justify-content: center; gap: 6px; }
.mod-card + .mod-card { margin-top: 12px; }
.card-name { font-family: 'DM Serif Display', Georgia, serif; font-size: 19px; color: #1c1917; line-height: 1.2; }
.card-desc { font-size: 13px; color: #57534e; line-height: 1.5; }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: SOLUTION COLUMNS (S2)
   Two-column card: outcomes left, inclusions right
   ═══════════════════════════════════════════════════════════════ */
.sc-slide  { background: #fffbf7; display: flex; flex-direction: column; padding: 44px 60px 0; }
.sc-header { margin-bottom: 12px; flex-shrink: 0; }

/* Card shell */
.sc-card         { flex: 1; border: 2px solid #1c1917; border-radius: 16px; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }
.sc-card-header  { background: #1c1917; text-align: center; padding: 10px 24px; flex-shrink: 0; }
.sc-card-title   { font-size: 16px; font-weight: 700; color: #fff; margin: 0; line-height: 1.3; }
.sc-card-sub     { font-size: 13px; font-weight: 400; color: rgba(255,255,255,0.75); margin: 0; }

/* Two columns */
.sc-columns { flex: 1; display: flex; min-height: 0; }
.sc-col     { flex: 1; display: flex; flex-direction: column; padding: 12px 20px; gap: 8px; border-right: 1px solid #e7dfd7; min-height: 0; }
.sc-col:last-child { border-right: none; }

/* Column pill header */
.sc-col-label { background: #062F7E; color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; text-align: center; padding: 5px 14px; border-radius: 100px; align-self: center; flex-shrink: 0; }

/* Optional tagline (left col only) */
.sc-tagline { font-size: 14px; font-style: italic; color: #c2410c; text-align: center; line-height: 1.4; flex-shrink: 0; margin: 0; }

/* Item list */
.sc-items      { flex: 1; display: flex; flex-direction: column; justify-content: space-evenly; min-height: 0; }
.sc-item       { display: flex; flex-direction: column; gap: 1px; }
.sc-item-title { font-size: 15px; font-weight: 700; color: #1c1917; line-height: 1.3; margin: 0; }
.sc-item-desc  { font-size: 13px; color: #57534e; line-height: 1.4; margin: 0; }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: SOLUTION OVERVIEW (S1)
   ═══════════════════════════════════════════════════════════════ */
.so-slide  { background: #fffbf7; display: flex; flex-direction: column; padding: 44px 60px 0; }
.so-header { margin-bottom: 14px; flex-shrink: 0; }

/* Main card */
.so-card       { flex: 1; border: 2px solid #1c1917; border-radius: 16px; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }
.so-card-title { background: #1c1917; color: #fff; text-align: center; font-size: 16px; font-weight: 600; padding: 10px 24px; flex-shrink: 0; letter-spacing: 0.02em; }

/* Rows */
.so-rows { flex: 1; display: flex; flex-direction: column; min-height: 0; }
.so-row  { flex: 1; display: flex; align-items: stretch; border-bottom: 1px solid #e7dfd7; }
.so-row:last-child { border-bottom: none; }

/* Label pill (left column) */
.so-label      { width: 196px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; padding: 12px 16px; background: #062F7E; }
.so-label-text { font-size: 15px; font-weight: 600; color: #fff; text-align: center; line-height: 1.3; }

/* Divider */
.so-sep { width: 3px; background: #e7dfd7; flex-shrink: 0; }

/* Content (right column) */
.so-content   { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 10px 28px; text-align: center; gap: 2px; }
.so-row-title { font-size: 15px; font-weight: 600; color: #1c1917; line-height: 1.4; margin: 0; }
.so-row-desc  { font-size: 15px; font-weight: 400; color: #57534e; line-height: 1.5; margin: 0; }

/* Logos strip */
.so-logos-strip { background: #eef2ff; border-top: 1.5px dashed #c7d2fe; padding: 5px 16px 6px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 3px; }
.so-logos-note  { font-size: 11px; font-weight: 700; color: #1c1917; text-align: center; margin: 0; }
.so-logos-img   { width: 100%; height: 32px; background-size: 440px auto; background-position: center -92px; background-repeat: no-repeat; }

/* Pills row (type: pills) */
.so-pills { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; padding: 2px 0; }
.so-pill  { color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 14px; border-radius: 100px; white-space: nowrap; }

/* Bullets row (type: bullets) */
.so-bullets { display: flex; flex-direction: column; gap: 3px; }
.so-bullet  { font-size: 15px; font-weight: 400; color: #1c1917; line-height: 1.4; margin: 0; text-align: left; padding-left: 16px; position: relative; }
.so-bullet::before { content: '●'; color: #c2410c; font-size: 8px; position: absolute; left: 0; top: 0; line-height: 21px; }

/* ─────────────────────────────────────────────────────────────────────────
   TEMPLATE: BLUEPRINT (S3) — 4-column day-by-day curriculum
   ───────────────────────────────────────────────────────────────────────── */
.sb-slide       { background: #fffbf7; display: flex; flex-direction: column; padding: 36px 60px 0; gap: 0; overflow: hidden; }
.sb-header      { flex-shrink: 0; margin-bottom: 16px; }

/* Day columns grid */
.sb-grid        { flex: 1; display: flex; gap: 10px; min-height: 0; }
.sb-col         { flex: 1; display: flex; flex-direction: column; gap: 8px; }

/* Day pill */
.sb-day-pill    { background: #062F7E; color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; text-align: center; padding: 5px 10px; border-radius: 100px; align-self: center; flex-shrink: 0; }

/* Section block */
.sb-section     { display: flex; flex-direction: column; min-height: 0; }
.sb-sec-header  { padding: 7px 12px; border-radius: 4px 4px 0 0; flex-shrink: 0; text-align: center; }
.sb-sec-title   { font-size: 16px; font-weight: 700; color: #fff; line-height: 1.3; margin: 0; text-align: center; }
.sb-sec-body    { border: 1.5px solid; border-top: none; border-radius: 0 0 4px 4px; padding: 7px 10px; display: flex; flex-direction: column; gap: 5px; flex: 1; }

/* Topic: bold headline + lighter sub-headline */
.sb-topic-wrap  { display: flex; flex-direction: column; gap: 2px; }
.sb-topic-title { font-size: 14px; font-weight: 700; color: #1c1917; line-height: 1.3; margin: 0; }
.sb-topic-desc  { font-size: 12px; font-weight: 400; color: #78716c; line-height: 1.4; margin: 0; }

/* Section colour pairs — each pair shares a learning arc (light = earlier, dark = deeper) */
/* Pair 1: Blue — foundational proficiency (AI-Native Pro → From Hammer to Scalpel) */
.sb-sec-blue-lt .sb-sec-header { background: #3b82f6; }
.sb-sec-blue-lt .sb-sec-body   { border-color: #bfdbfe; }
.sb-sec-blue-dk .sb-sec-header { background: #1e3a8a; }
.sb-sec-blue-dk .sb-sec-body   { border-color: #93c5fd; }

/* Pair 2: Teal — agent building (Your First Agent → Compound Intelligence) */
.sb-sec-teal-lt .sb-sec-header { background: #0d9488; }
.sb-sec-teal-lt .sb-sec-body   { border-color: #99f6e4; }
.sb-sec-teal-dk .sb-sec-header { background: #0f766e; }
.sb-sec-teal-dk .sb-sec-body   { border-color: #5eead4; }

/* Pair 3: Amber — safety / deployment (Safe by Design → Make It Stick) */
.sb-sec-amber-lt .sb-sec-header { background: #d97706; }
.sb-sec-amber-lt .sb-sec-body   { border-color: #fde68a; }
.sb-sec-amber-dk .sb-sec-header { background: #b45309; }
.sb-sec-amber-dk .sb-sec-body   { border-color: #fcd34d; }

/* ─────────────────────────────────────────────────────────────────────────
   REFERENCE TABLE — box type summary (reference_table)
   ───────────────────────────────────────────────────────────────────────── */
.ref-slide       { background: #fffbf7; display: flex; flex-direction: column; padding: 36px 60px 0; gap: 0; overflow: hidden; }
.ref-table-head  { flex-shrink: 0; margin-bottom: 14px; }
.ref-table-body  { flex: 1; display: flex; flex-direction: column; border: 1.5px solid #e7dfd7; border-radius: 8px; overflow: hidden; }
.ref-row         { display: flex; align-items: center; border-bottom: 1px solid #e7dfd7; }
.ref-row:last-child { border-bottom: none; }
.ref-row-header  { background: #1c1917; flex-shrink: 0; }
.ref-row-even    { background: #faf7f4; }
.ref-col-short   { width: 60px;  flex-shrink: 0; padding: 7px 14px; }
.ref-col-name    { width: 156px; flex-shrink: 0; padding: 7px 12px; border-left: 1px solid #e7dfd7; }
.ref-col-desc    { flex: 1; padding: 7px 14px; border-left: 1px solid #e7dfd7; }
.ref-th          { font-size: 11px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
.ref-short       { font-size: 15px; font-weight: 700; color: #062F7E; margin: 0; line-height: 1; }
.ref-name        { font-size: 12px; color: #78716c; margin: 0; font-style: italic; }
.ref-desc        { font-size: 12px; color: #44403c; margin: 0; line-height: 1.35; }

/* ─────────────────────────────────────────────────────────────────────────
   SKETCH LAYOUT — dynamic assembler template (sketch_layout)
   Design area uses position:relative; boxes are absolutely positioned
   using %L (= % of container width) and %H (= % of container height)
   ───────────────────────────────────────────────────────────────────────── */
.ns-slide       { background: #fffbf7; display: flex; flex-direction: column; padding: 36px 60px 0; gap: 0; overflow: hidden; }
.ns-header      { flex-shrink: 0; margin-bottom: 16px; }
.ns-design-area { flex: 1; position: relative; min-height: 0; }

/* content-card (CC) box type */
.ns-card        { position: absolute; display: flex; flex-direction: column; border-radius: 8px; border: 2px solid #1c1917; overflow: hidden; }
.ns-card-header { background: #1c1917; padding: 10px 16px; flex-shrink: 0; }
.ns-card-title  { font-size: 15px; font-weight: 600; color: #fff; margin: 0; line-height: 1.3; }
.ns-card-sub    { font-size: 13px; font-weight: 400; color: rgba(255,255,255,0.7); margin: 0; line-height: 1.4; }
.ns-card-body   { flex: 1; padding: 14px 16px; background: #fff; display: flex; flex-direction: column; gap: 8px; overflow: hidden; }
.ns-card-text   { font-size: 15px; font-weight: 600; color: #1c1917; margin: 0; line-height: 1.3; }
.ns-card-desc   { font-size: 14px; font-weight: 400; color: #57534e; margin: 0 0 4px; line-height: 1.5; }
/* CC color variants — applied on .ns-card wrapper */
.ns-card-blue-lt  { border-color: #3b82f6; } .ns-card-blue-lt  .ns-card-header { background: #3b82f6; }
.ns-card-blue-dk  { border-color: #1e3a8a; } .ns-card-blue-dk  .ns-card-header { background: #1e3a8a; }
.ns-card-teal-lt  { border-color: #0d9488; } .ns-card-teal-lt  .ns-card-header { background: #0d9488; }
.ns-card-teal-dk  { border-color: #0f766e; } .ns-card-teal-dk  .ns-card-header { background: #0f766e; }
.ns-card-amber-lt { border-color: #d97706; } .ns-card-amber-lt .ns-card-header { background: #d97706; }
.ns-card-amber-dk { border-color: #b45309; } .ns-card-amber-dk .ns-card-header { background: #b45309; }

/* circle-text (CT) box type */
.ns-circle       { position: absolute; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 16px; background: #fff7ed; border: 2px solid #c2410c; gap: 4px; }
.ns-circle-title { font-family: 'DM Serif Display', Georgia, serif; font-size: 20px; font-weight: 400; color: #1c1917; margin: 0; line-height: 1.2; }
.ns-circle-desc  { font-size: 13px; font-weight: 400; color: #78716c; margin: 0; line-height: 1.3; }
/* CT color variants — applied directly on .ns-circle */
.ns-circle-blue-lt  { background: #eff6ff; border-color: #3b82f6; }
.ns-circle-blue-dk  { background: #dbeafe; border-color: #1e3a8a; }
.ns-circle-teal-lt  { background: #f0fdfa; border-color: #0d9488; }
.ns-circle-teal-dk  { background: #ccfbf1; border-color: #0f766e; }
.ns-circle-amber-lt { background: #fffbeb; border-color: #d97706; }
.ns-circle-amber-dk { background: #fef3c7; border-color: #b45309; }

/* stat-block (ST) box type */
.ns-stat        { position: absolute; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 20px; background: #fff; border: 2px solid #e7dfd7; border-radius: 8px; }
.ns-stat-number { font-family: 'DM Serif Display', Georgia, serif; font-size: 56px; color: #c2410c; line-height: 1; margin: 0; }
.ns-stat-label  { font-size: 14px; font-weight: 500; color: #78716c; margin: 8px 0 0; line-height: 1.35; }

/* statement-block (SQ) box type */
.ns-statement      { position: absolute; display: flex; flex-direction: column; justify-content: center; padding: 28px 32px; background: #fff7ed; border-left: 4px solid #c2410c; border-radius: 0 8px 8px 0; }
.ns-statement-text { font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; color: #1c1917; line-height: 1.45; margin: 0; }
.ns-statement-attr { font-size: 13px; color: #a8a29e; margin: 14px 0 0; line-height: 1.4; }

/* item-list (IL) box type */
.ns-item-list  { position: absolute; display: flex; flex-direction: column; justify-content: space-evenly; padding: 16px 20px; }
.ns-il-item    { display: flex; flex-direction: column; gap: 2px; }
.ns-il-title   { font-size: 15px; font-weight: 700; color: #1c1917; line-height: 1.3; margin: 0; }
.ns-il-desc    { font-size: 13px; color: #57534e; line-height: 1.35; margin: 0; }

/* label (LB) box type — column/section label for reference slides */
.ns-label      { position: absolute; display: flex; align-items: center; justify-content: center; }
.ns-label-text { font-size: 20px; font-weight: 600; color: #062F7E; text-align: center; margin: 0; }

/* col-label-pill (LP) box type */
.ns-pill      { position: absolute; display: flex; align-items: center; justify-content: center; }
.ns-pill-text { background: #062F7E; color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 16px; border-radius: 100px; white-space: nowrap; }

/* zone-header (ZH) box type */
.ns-zone-header   { position: absolute; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; padding: 0 16px; border-radius: 6px; }
.ns-zone-title    { font-size: 15px; font-weight: 700; color: #fff; margin: 0; line-height: 1.2; }
.ns-zone-sub      { font-size: 12px; color: rgba(255,255,255,0.75); margin: 3px 0 0; }
.ns-zone-blue-lt  { background: #3b82f6; }
.ns-zone-blue-dk  { background: #1e3a8a; }
.ns-zone-teal-lt  { background: #0d9488; }
.ns-zone-teal-dk  { background: #0f766e; }
.ns-zone-amber-lt { background: #d97706; }
.ns-zone-amber-dk { background: #b45309; }
.ns-zone-charcoal { background: #1c1917; }

/* row-item (RI) box type */
.ns-row-item      { position: absolute; display: flex; border-radius: 8px; overflow: hidden; border: 1px solid #e7dfd7; }
.ns-ri-label      { background: #062F7E; display: flex; align-items: center; justify-content: center; padding: 8px 14px; flex-shrink: 0; min-width: 80px; }
.ns-ri-label-text { font-size: 13px; font-weight: 700; color: #fff; margin: 0; text-align: center; line-height: 1.3; }
.ns-ri-content    { flex: 1; padding: 10px 16px; background: #fff; display: flex; flex-direction: column; justify-content: center; gap: 2px; }
.ns-ri-text       { font-size: 15px; font-weight: 600; color: #1c1917; margin: 0; line-height: 1.3; }
.ns-ri-desc       { font-size: 13px; color: #57534e; margin: 0; line-height: 1.35; }

/* image-block (IB) box type */
.ns-image-block { position: absolute; background-size: cover; background-color: #e7dfd7; border-radius: 8px; overflow: hidden; }

/* ── SAMPLE BANNER — shared across S-templates, centered in bottom-bar ── */
.slide-banner {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  background: transparent;
  border-top: 1.5px solid #78716c;
  border-bottom: 1.5px solid #78716c;
  padding: 3px 16px;
  font-size: 11px;
  font-weight: 500;
  color: #57534e;
  letter-spacing: 0.03em;
  white-space: nowrap;
}

/* ── INLINE FORMATTING ── */
strong { font-weight: 700; }
em     { font-style: italic; }
.accent    { color: #c2410c; }
.kc-navy   { color: #062F7E; }
.kc-muted  { color: #78716c; }
.kc-white  { color: #ffffff; }
.kc-dark   { color: #1c1917; }
.kc-teal   { color: #0f766e; }
.kc-brown  { color: #92400e; }

/* ── TOOLTIP BODY LINE (no bullet) ── */
.tt-body { font-size: 10.5px; color: #78716c; line-height: 1.35; padding-left: 10px; margin-bottom: 3px; }


/* ─────────────────────────────────────────────────────────────────────────
   END PAGE (E1) — signature / contact placeholder
   ───────────────────────────────────────────────────────────────────────── */
.end-slide {
  background: #fafaf9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 120px;
  position: relative;
}
.end-logo { position: absolute; top: 40px; left: 60px; }
.end-content { display: flex; flex-direction: column; align-items: center; gap: 0; width: 100%; }
.end-headline { font-family: "DM Serif Display", Georgia, serif; font-size: 56px; color: #1c1917; text-align: center; line-height: 1.1; margin-bottom: 28px; }
.end-divider { width: 48px; height: 2px; background: #c2410c; margin-bottom: 40px; }
.end-contacts { display: flex; align-items: flex-start; gap: 0; width: 600px; }
.end-contact { flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; }
.end-contact-name { font-size: 18px; font-weight: 600; color: #1c1917; line-height: 1.3; }
.end-contact-detail { font-size: 14px; color: #78716c; line-height: 1.6; }
.end-contact-sep { width: 1px; background: #e7e5e4; margin: 0 40px; align-self: stretch; flex-shrink: 0; }
.end-tagline { font-size: 13px; color: #a8a29e; margin-top: 40px; letter-spacing: 0.04em; }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: AI INFLECTION (I2)
   ═══════════════════════════════════════════════════════════════ */
.ai-inflection-slide {
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  padding: 44px 60px 0;
}

.ai-header    { margin-bottom: 14px; flex-shrink: 0; }
.ai-eyebrow   { font-size: 14px; font-weight: 600; color: #c2410c; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 8px; flex-shrink: 0; }
.ai-headline  { font-family: 'DM Serif Display', Georgia, serif; font-size: 32px; font-weight: 400; line-height: 1.25; color: #1c1917; letter-spacing: -0.02em; flex-shrink: 0; }

.ai-main { display: grid; grid-template-columns: 1fr 340px; gap: 16px; flex: 1; min-height: 0; }
.ai-left { display: flex; flex-direction: column; gap: 12px; min-height: 0; }

/* News cards */
.ai-news      { display: flex; flex-direction: column; gap: 10px; flex-shrink: 0; }
.ai-news-card { background: #ffffff; border: 1px solid #e7dfd7; border-radius: 10px; padding: 14px 16px; display: flex; flex-direction: column; gap: 5px; }
.ai-news-headline { font-size: 15px; font-weight: 600; color: #1c1917; line-height: 1.4; }
.ai-news-meta     { font-size: 12px; font-weight: 600; color: #a8a29e; text-transform: uppercase; letter-spacing: 0.08em; }

/* Staircase */
.ai-staircase { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; align-items: end; flex: 1; min-height: 0; }
.ai-year-card { background: #ffffff; border: 1px solid #fed7aa; border-radius: 10px; padding: 14px 14px 12px; display: flex; flex-direction: column; }
.ai-card-y1   { height: 200px; }
.ai-card-y2   { height: 248px; }
.ai-card-y3   { height: 296px; }
.ai-year-pill { display: inline-flex; align-items: center; background: #1c1917; color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 100px; margin-bottom: 7px; width: fit-content; flex-shrink: 0; }
.ai-descriptor { font-size: 15px; font-weight: 600; color: #c2410c; margin-bottom: 4px; line-height: 1.3; flex-shrink: 0; }
.ai-metr       { font-size: 13px; font-weight: 500; color: #78716c; margin-bottom: 8px; flex-shrink: 0; }
.ai-divider    { width: 100%; height: 1px; background: #fed7aa; margin-bottom: 8px; flex-shrink: 0; }
.ai-capability { font-size: 15px; color: #57534e; line-height: 1.4; margin-bottom: 4px; }

/* Hero card */
.ai-hero-card { background: #fff7ed; border: 2px solid #c2410c; border-radius: 12px; padding: 20px 18px; display: flex; flex-direction: column; }
.ai-hero-card .ai-year-pill     { background: #c2410c; font-size: 12px; padding: 4px 12px; }
.ai-hero-descriptor             { font-size: 15px; font-weight: 600; color: #c2410c; margin: 10px 0 12px; }
.ai-hero-number                 { font-family: 'DM Serif Display', Georgia, serif; font-size: 64px; color: #c2410c; line-height: 1; margin-bottom: 4px; }
.ai-hero-label                  { font-size: 13px; font-weight: 500; color: #78716c; margin-bottom: 16px; }
.ai-hero-card .ai-divider       { background: #f6c59a; }
.ai-hero-card .ai-capability    { font-size: 15px; color: #44403c; }

/* Bottom bar footnote (I2) — sits right of logo via shared .bottom-bar gap:10px */
.ai-footnote { font-size: 9.5px; color: #a8a29e; line-height: 1.5; flex: 1; }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: PEOPLE PROCESS ROI (I3)
   ═══════════════════════════════════════════════════════════════ */
.ppr-slide {
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  padding: 44px 60px 0;
}

.ppr-header       { margin-bottom: 28px; flex-shrink: 0; }

.ppr-diagram-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ppr-diagram-wrapper {
  position: relative;
  width: 720px;
  height: 440px;
}

/* Circles */
.ppr-circle {
  position: absolute;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 24px;
  gap: 5px;
}

.ppr-circle-roi     { left: 240px; top: 0;     background: #fff7ed; border: 2px solid #c2410c; }
.ppr-circle-people  { left: 0;     top: 200px; background: #f5f0eb; border: 1.5px solid #1c1917; }
.ppr-circle-process { left: 480px; top: 200px; background: #f5f0eb; border: 1.5px solid #1c1917; }

.ppr-circle-label {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 22px;
  font-weight: 400;
  color: #1c1917;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.ppr-circle-sub { font-size: 15px; color: #78716c; line-height: 1.3; }
.ppr-circle-roi .ppr-circle-sub { color: #c2410c; }

/* Arrows — pure CSS, no SVG */
.ppr-arrow {
  position: absolute;
  height: 1.6px;
  background: #a8a29e;
  transform-origin: 0 50%;
}

.ppr-arrow::after {
  content: '';
  position: absolute;
  right: -7px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 5px solid transparent;
  border-bottom: 5px solid transparent;
  border-left: 7px solid #a8a29e;
}

/* Arrow 1: People → Process (horizontal) */
.ppr-arrow-1 { left: 242px; top: 319px; width: 232px; }
/* Arrow 2: Process → ROI */
.ppr-arrow-2 { left: 508px; top: 243px; width: 62px; transform: rotate(-140deg); }
/* Arrow 3: ROI → People */
.ppr-arrow-3 { left: 268px; top: 197px; width: 62px; transform: rotate(140deg); }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: PRACTITIONERS (I5)
   Full-height two-column layout — no top slide padding
   ═══════════════════════════════════════════════════════════════ */
.i5-slide { background: #fffbf7; display: flex; flex-direction: column; }

.i5-main  { flex: 1; display: flex; min-height: 0; }

/* Left column */
.i5-left {
  width: 400px;
  flex-shrink: 0;
  background: #f5f0eb;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 32px;
  padding: 40px;
  position: relative;
}

.i5-left::after {
  content: '';
  position: absolute;
  right: 0; top: 8%; bottom: 8%;
  width: 4px;
  background: #c2410c;
  border-radius: 2px;
}

/* Center the shared eyebrow + headline inside the left column */
.i5-left .eyebrow  { text-align: center; }
.i5-left .headline { text-align: center; }

/* Company box */
.i5-company-box { border: 1.5px dashed #c2410c; border-radius: 10px; padding: 12px 16px 16px; }

.i5-company-box-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #c2410c;
  text-align: center;
  margin-bottom: 12px;
}

.i5-logos-strip {
  display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
  gap: 8px 12px; min-height: 60px;
}
.i5-logos-strip img {
  height: 20px; width: auto; display: block;
  mix-blend-mode: darken; opacity: 0.85;
}

/* Right column */
.i5-right { flex: 1; display: flex; flex-direction: column; min-width: 0; padding-right: 120px; }

.i5-panel-header {
  background: #1c1917;
  padding: 13px 28px;
  font-size: 16px;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  line-height: 1.4;
  flex-shrink: 0;
  border-radius: 10px;
  margin: 20px 0 0 16px;
}

/* Practitioners 3×4 grid */
.i5-grid {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(4, 1fr);
  gap: 1px;
  background: #e7dfd7;
  min-height: 0;
  margin-top: 1px;
}

.i5-card {
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12px 10px;
  gap: 6px;
  text-align: center;
}

/* Photo (real image) */
.i5-photo { width: 54px; height: 54px; border-radius: 50%; overflow: hidden; flex-shrink: 0; background: #fffbf7; }
.i5-photo img { width: 100%; height: 100%; object-fit: cover; mix-blend-mode: multiply; }

/* Avatar (initials placeholder) */
.i5-avatar {
  width: 54px; height: 54px;
  border-radius: 50%;
  background: #e7dfd7;
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 20px; color: #78716c; flex-shrink: 0;
}

.i5-card-name { font-size: 15px; font-weight: 700; color: #1c1917; line-height: 1.2; }

.i5-card-companies { display: flex; align-items: center; justify-content: center; gap: 5px; flex-wrap: wrap; }

.i5-co-tag {
  font-size: 11px; font-weight: 700; color: #78716c;
  letter-spacing: 0.03em; background: #f0ece8;
  border-radius: 3px; padding: 2px 5px; white-space: nowrap;
}
.i5-co-logo { padding: 2px 4px; display: inline-flex; align-items: center; background: transparent; }
.i5-co-logo img { height: 14px; width: auto; display: block; mix-blend-mode: multiply; }
.i5-co-logo img[alt="Amazon"],
.i5-co-logo img[alt="Google"],
.i5-co-logo img[alt="Airbnb"] { height: 18px; }

/* Bottom bar override — full-width with own padding (no slide padding on this layout) */
.i5-bottom {
  display: flex; align-items: center;
  padding: 10px 60px 16px;
  flex-shrink: 0;
  margin-top: auto;
}

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: IK FOUNDATIONS CONTINUUM (IK-S17)
   ═══════════════════════════════════════════════════════════════ */
.fc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}
.fc-card {
  background: #ffffff;
  border: 1px solid #ffedd5;
  border-top-width: 3px;
  border-radius: 0 0 14px 14px;
  padding: 20px 18px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.fc-card--highlight {
  background: #fff7ed;
  border: 2px solid #c2410c;
  border-top-width: 3px;
  box-shadow: 0 0 40px rgba(194,65,12,0.10);
}
.fc-card-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 8px;
  flex-shrink: 0;
}
.fc-card-title {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 22px;
  color: #1c1917;
  line-height: 1.2;
  margin-bottom: 10px;
  flex-shrink: 0;
}
.fc-card--highlight .fc-card-title { color: #c2410c; }
.fc-card-body {
  font-size: 14px;
  color: #57534e;
  line-height: 1.55;
  margin-bottom: 12px;
  flex: 1;
}
.fc-card-note {
  font-size: 12px;
  padding: 10px 12px;
  background: #fef6ee;
  border-radius: 8px;
  color: #a8a29e;
  font-style: italic;
  line-height: 1.5;
  flex-shrink: 0;
}
.fc-card--highlight .fc-card-note {
  background: #ffffff;
  border: 1px solid #fed7aa;
  color: #1c1917;
  font-style: normal;
  font-weight: 500;
}
/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: IK STATEMENT IMAGE SPLIT (IK-I7)
   ═══════════════════════════════════════════════════════════════ */
.iks-slide {
  display: flex;
  flex-direction: row;
  border-radius: 16px;
  overflow: hidden;
}
.iks-left {
  width: 50%;
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 56px 48px 70px;
  position: relative;
}
.iks-statements {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.iks-box {
  background: #ffffff;
  border: 1px solid #ffedd5;
  border-left: 4px solid #c2410c;
  border-radius: 0 12px 12px 0;
  padding: 20px 24px;
}
.iks-box p {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 32px;
  color: #1c1917;
  line-height: 1.25;
}
.iks-right {
  width: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: IK AGENT USE CASES (IK-S19)
   ═══════════════════════════════════════════════════════════════ */
.agc-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.agc-card {
  background: #ffffff;
  border: 1px solid #ffedd5;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.agc-card-img {
  height: 130px;
  background-size: cover;
  background-position: center top;
}
.agc-card-body {
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.agc-card-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #c2410c;
}
.agc-card-title {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 17px;
  color: #1c1917;
  line-height: 1.25;
}
.agc-card-desc {
  font-size: 13px;
  color: #57534e;
  line-height: 1.55;
}

.fc-takeaway {
  padding: 13px 20px;
  background: #fef6ee;
  border-left: 3px solid #c2410c;
  border-radius: 8px;
  font-size: 15px;
  color: #1c1917;
  line-height: 1.6;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: ACCELER INTRO (I4)
   ═══════════════════════════════════════════════════════════════ */
.ai4-slide {
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  padding: 44px 60px 0;
}

.ai4-header { margin-bottom: 20px; flex-shrink: 0; }

.ai4-content { flex: 1; display: flex; gap: 0; min-height: 0; }

/* Stats column */
.ai4-stats-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-right: 40px;
  position: relative;
}

.ai4-stats-col::after {
  content: '';
  position: absolute;
  right: 0; top: 8%; bottom: 8%;
  width: 4px;
  background: #c2410c;
  border-radius: 2px;
}

.ai4-subheading {
  font-size: 17px;
  font-weight: 700;
  color: #1c1917;
  margin-bottom: 14px;
  padding-top: 10px;
  letter-spacing: -0.01em;
  text-align: center;
  flex-shrink: 0;
}

.ai4-stats-divider { width: 100%; height: 1.5px; background: #e7dfd7; margin-bottom: 16px; flex-shrink: 0; }

.ai4-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  flex: 1;
  margin-top: 8px;
}

.ai4-stat { padding: 6px 0; text-align: center; }
.ai4-stat:nth-child(odd)  { padding-right: 1px; }
.ai4-stat:nth-child(even) { padding-left:  1px; }

.ai4-stat-number {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 38px;
  font-weight: 400;
  color: #c2410c;
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: 4px;
}

.ai4-stat-label { font-size: 15px; font-weight: 400; color: #78716c; line-height: 1.3; }

/* Badges column */
.ai4-badges-col {
  width: 220px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding-left: 32px;
  flex-shrink: 0;
}

.ai4-badge { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; }
.ai4-badge img { display: block; }
.ai4-badge-caption { font-size: 15px; font-weight: 600; color: #44403c; line-height: 1.3; text-align: center; }
.ai4-badge-sep { width: 40px; height: 4px; background: #c2410c; border-radius: 2px; }

/* Logos strip — bleeds to slide edges via negative margin */
.ai4-logos-row {
  height: 56px;
  background-color: #f5f0eb;
  background-repeat: no-repeat;
  background-size: 800px auto;
  background-position: center -171px;
  background-blend-mode: darken;
  margin: 16px -60px 0;
  flex-shrink: 0;
}

/* ─────────────────────────────────────────────────────────────────────────
   CLOSING SLIDE (F2) — logo + tagline + contacts
   Supports dark and light themes via .closing-dark / .closing-light
   ───────────────────────────────────────────────────────────────────────── */
.closing-slide    { display: flex; flex-direction: column; align-items: center; }
.closing-dark     { background: #1c1917; }
.closing-light    { background: #fffbf7; }

.closing-body     { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0 80px; gap: 0; }
.closing-logo     { margin-bottom: 20px; }
.closing-tagline  { font-family: 'DM Serif Display', Georgia, serif; font-size: 44px; font-weight: 400; text-align: center; line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 24px; }
.closing-dark  .closing-tagline { color: #ffffff; }
.closing-light .closing-tagline { color: #1c1917; }

.closing-divider  { width: 48px; height: 2px; background: #c2410c; margin-bottom: 32px; }

.closing-contacts { display: flex; align-items: flex-start; }
.closing-contact  { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 0 36px; }
.closing-contact + .closing-contact { border-left: 1px solid rgba(255,255,255,0.12); }
.closing-light .closing-contact + .closing-contact { border-left-color: #e7dfd7; }

.closing-name     { font-size: 22px; font-weight: 700; margin: 0 0 6px; line-height: 1.2; }
.closing-dark  .closing-name  { color: #ffffff; }
.closing-light .closing-name  { color: #1c1917; }

.closing-role     { font-size: 20px; margin: 0; line-height: 1.4; }
.closing-dark  .closing-role  { color: rgba(255,255,255,0.5); }
.closing-light .closing-role  { color: #78716c; }

.closing-email    { font-size: 20px; color: #c2410c; margin: 8px 0 0; }

.closing-foot     { width: 100%; padding: 14px 48px; box-sizing: border-box; }
.closing-dark  .closing-foot  { border-top: 1px solid rgba(255,255,255,0.08); }
.closing-light .closing-foot  { border-top: 1px solid #e7dfd7; }
.closing-conf     { font-size: 9px; letter-spacing: 0.04em; margin: 0; }
.closing-dark  .closing-conf  { color: rgba(255,255,255,0.3); }
.closing-light .closing-conf  { color: #a8a29e; }

/* ══════════════════════════════════════════════════════════════════
   USE CASE — use_case template  (1-col and 2-col layouts)
   Fields: eyebrow · headline · subhead · section_label · layout · cases[]
══════════════════════════════════════════════════════════════════ */
.uc-slide        { background: #fffbf7; display: flex; flex-direction: column; padding: 44px 60px 0; }
.uc-header       { flex-shrink: 0; margin-bottom: 14px; }
.slide-sub       { font-size: 15px; color: #78716c; margin: 5px 0 0; line-height: 1.4; }
.uc-bar          { flex-shrink: 0; background: #1c1917; border-radius: 6px; padding: 11px 20px; margin-bottom: 10px; }
.uc-bar-text     { font-size: 15px; font-weight: 600; color: #ffffff; text-align: center; margin: 0; letter-spacing: 0.02em; }

/* 1-col card */
.uc-card         { flex: 1; background: #ffffff; border: 1px solid #e7dfd7; border-radius: 10px; display: flex; flex-direction: column; justify-content: space-evenly; padding: 20px 48px; overflow: hidden; }
.uc-case         { text-align: center; }
.uc-case-title   { font-size: 17px; font-weight: 600; color: #1c1917; margin: 0 0 5px; line-height: 1.3; }
.uc-case-body    { font-size: 15px; color: #78716c; margin: 0; line-height: 1.5; }
.uc-case-divider { height: 1px; background: #e7dfd7; flex-shrink: 0; }

/* 2-col layout */
.uc-cols         { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; overflow: hidden; }
.uc-col-card     { background: #ffffff; border: 1px solid #e7dfd7; border-radius: 10px; display: flex; flex-direction: column; justify-content: space-evenly; padding: 20px 32px; overflow: hidden; }

/* ══════════════════════════════════════════════════════════════════
   MODULE TABLE — module_table template
   Exceptions: table-cell text 14px (compact structured label, like
   blueprint topic-title); col headers 12px (badge/structural label);
   tag pills 11px (badge/pill exception)
   Fields: eyebrow · headline · subhead · col_* · rows[i]:
           { module, badge, outcome, tags, duration, color }
══════════════════════════════════════════════════════════════════ */
.mt-slide    { background: #fffbf7; display: flex; flex-direction: column; padding: 44px 60px 0; }
.mt-header   { flex-shrink: 0; margin-bottom: 12px; }
/* .mt-subhead replaced by shared .slide-sub */

/* Table shell */
.mt-table    { flex: 1; display: flex; flex-direction: column; border: 1.5px solid #1c1917; border-radius: 10px; overflow: hidden; min-height: 0; }

/* Column header row */
.mt-thead    { display: grid; grid-template-columns: 220px 1fr 200px 84px; background: #1c1917; flex-shrink: 0; }
.mt-th       { font-size: 10px; font-weight: 700; color: #ffffff; padding: 9px 14px; letter-spacing: 0.08em; text-transform: uppercase; text-align: center; border-right: 1px solid rgba(255,255,255,0.12); }
.mt-th:last-child { border-right: none; }

/* Data rows */
.mt-tbody    { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.mt-row      { display: grid; grid-template-columns: 220px 1fr 200px 84px; border-top: 1px solid #e7dfd7; min-height: 0; }

/* Module cell */
.mt-mod      { display: flex; flex-direction: column; justify-content: center; padding: 8px 12px; border-right: 1px solid rgba(255,255,255,0.15); background: #1c1917; overflow: hidden; }
.mt-mod-text { font-size: 12px; font-weight: 700; color: #ffffff; line-height: 1.3; margin: 0; }
.mt-mod-badge { margin-top: 5px; display: inline-block; border: 1.5px solid rgba(255,255,255,0.45); border-radius: 20px; padding: 2px 9px; font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.8); letter-spacing: 0.05em; align-self: flex-start; }

/* Module color variants */
.mt-mod-dark   { background: #1c1917; }
.mt-mod-teal   { background: #0f766e; }
.mt-mod-navy   { background: #1e3a8a; }
.mt-mod-accent { background: #c2410c; }
.mt-mod-amber  { background: #b45309; }

/* Outcome cell */
.mt-outcome  { padding: 8px 14px; border-right: 1px solid #e7dfd7; display: flex; align-items: center; min-width: 0; overflow: hidden; }
.mt-out-wrap { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.mt-out-text { font-size: 10px; color: #1c1917; line-height: 1.45; margin: 0; }
.mt-out-desc { font-size: 10px; color: #1c1917; line-height: 1.45; margin: 0; }

/* Tags cell */
.mt-tags     { padding: 6px 8px; border-right: 1px solid #e7dfd7; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; overflow: hidden; }
.mt-tag      { background: #c2410c; color: #ffffff; font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 20px; letter-spacing: 0.04em; text-align: center; max-width: 100%; word-break: break-word; }

/* Duration cell */
.mt-dur      { display: flex; align-items: center; justify-content: center; overflow: hidden; }
.mt-dur-text { font-size: 14px; font-weight: 600; color: #1c1917; }

/* ── Accelerator Sessions — shared bottom bar (as-) ─────────────────────── */
.as-footer       { display:flex; align-items:center; flex-shrink:0; padding-top:10px; }
.as-solution-tag { font-family:'DM Sans',sans-serif; font-size:9px; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:0.1em; background:linear-gradient(90deg,#f97316,#ec4899); padding:5px 12px; border-radius:4px; flex-shrink:0; }
.as-footer-line  { flex:1; height:2px; background:#1c1917; margin:0 16px; }
.as-footer-right { display:flex; align-items:center; gap:8px; flex-shrink:0; }
.as-confidential { font-family:'DM Sans',sans-serif; font-size:9px; color:#78716c; }

/* ── A1 · The Mirror (tm-) ──────────────────────────────────────────────── */
.tm-slide      { display:flex; flex-direction:column; }
.tm-body       { flex:1; display:flex; gap:24px; min-height:0; margin-top:14px; }
.tm-card       { flex:1; display:flex; flex-direction:column; border-radius:12px; overflow:hidden; box-shadow:0 2px 16px rgba(0,0,0,0.09); }
.tm-card-hdr   { background:#1c1917; padding:15px 20px; text-align:center; }
.tm-hdr-line1  { font-family:'DM Sans',sans-serif; font-size:16px; font-weight:700; color:#fff; margin:0; line-height:1.3; }
.tm-hdr-line2  { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:rgba(255,255,255,0.88); margin:5px 0 0; line-height:1.3; }
.tm-card-body  { flex:1; background:#fff; padding:20px 24px; display:flex; flex-direction:column; justify-content:space-evenly; overflow:hidden; }
.tm-intro      { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:500; line-height:1.5; color:#44403c; margin:0; }
.tm-step       { font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.55; color:#1c1917; margin:0; }
.tm-chart-body { flex:1; background:#fff; padding:16px 20px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; overflow:hidden; }
.tm-chart-cap  { font-family:'DM Sans',sans-serif; font-size:10px; color:#78716c; text-align:center; flex-shrink:0; }

/* ── A2 · The Lens (tl-) ────────────────────────────────────────────────── */
.tl-body { display:flex; gap:24px; min-height:0; }

/* ── A3 · The Process X-Ray (xr-) ───────────────────────────────────────── */
.xr-body        { display:flex; gap:12px; min-height:0; }
.xr-col         { flex:1; display:flex; flex-direction:column; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.08); }
.xr-col-hdr     { display:flex; align-items:center; gap:10px; text-align:left; }
.xr-col-num     { width:26px; height:26px; border-radius:50%; background:#c2410c; color:#fff; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.xr-col-title   { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; color:#fff; margin:0; line-height:1.3; }
.xr-col-body    { flex:1; background:#fff; padding:14px 16px; display:flex; flex-direction:column; gap:8px; overflow:hidden; }
.xr-pill        { padding:8px 12px; border-radius:8px; font-family:'DM Sans',sans-serif; font-size:15px; font-weight:600; text-align:center; }
.xr-pill--blue  { background:#dbeafe; color:#1e3a8a; }
.xr-pill--purple{ background:#ede9fe; color:#4c1d95; }
.xr-para        { font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.5; color:#1c1917; margin:0; }

/* ── A5 · The Commit (tc-) ───────────────────────────────────────────────── */
.tc-body        { display:flex; gap:24px; min-height:0; }
.tc-card-body   { flex:1; background:#fff; padding:16px 20px; display:flex; flex-direction:column; gap:6px; overflow:hidden; }
.tc-step        { font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.5; color:#1c1917; margin:0; }
.tc-chart-body  { flex:1; background:#fff; padding:12px 14px; display:flex; overflow:hidden; }
.tc-roadmap     { flex:1; display:flex; flex-direction:column; gap:5px; }
.tc-rm-header   { display:flex; justify-content:space-between; align-items:center; padding:6px 8px; background:#fafaf9; border:1px solid #e7dfd7; border-radius:6px; flex-shrink:0; }
.tc-rm-title    { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:600; color:#1c1917; }
.tc-rm-meta     { font-family:'DM Sans',sans-serif; font-size:9px; color:#78716c; }
.tc-rm-grid     { display:grid; grid-template-columns:1fr 1fr; grid-auto-rows:1fr; gap:5px; flex:2; min-height:0; }
.tc-rm-cell     { border:1px solid #e7dfd7; border-radius:5px; padding:7px 8px; background:#fafaf9; }
.tc-rm-full     { border:1px solid #e7dfd7; border-radius:5px; padding:7px 8px; background:#fafaf9; flex:1; min-height:0; }
.tc-rm-num      { font-family:'DM Sans',sans-serif; font-size:8px; font-weight:700; color:#c2410c; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:3px; }
.tc-rm-q        { font-family:'DM Sans',sans-serif; font-size:8px; color:#78716c; line-height:1.4; font-style:italic; }
.tc-rm-actions  { display:grid; grid-template-columns:1fr 1fr 1fr; background:#1e3a8a; border-radius:5px; overflow:hidden; flex-shrink:0; }
.tc-rm-action   { padding:7px 8px; border-right:1px solid rgba(255,255,255,0.15); }
.tc-rm-action:last-child { border-right:none; }
.tc-rm-act-ttl  { font-family:'DM Sans',sans-serif; font-size:8px; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:0.06em; }
.tc-rm-act-sub  { font-family:'DM Sans',sans-serif; font-size:7px; color:rgba(255,255,255,0.75); line-height:1.4; margin-top:2px; }

/* ── A6 · After the Accelerator (aa-) ────────────────────────────────────── */
.aa-label       { font-family:'DM Sans',sans-serif; font-size:22px; font-weight:600; color:#fff; margin:0 0 14px; flex-shrink:0; }
.aa-statement   { font-family:'DM Serif Display',serif; font-size:30px; font-weight:400; color:#fff; margin:0; line-height:1.35; flex-shrink:0; }
.aa-rule        { height:1px; background:rgba(255,255,255,0.18); flex-shrink:0; margin-top:14px; }
.aa-cards       { display:flex; gap:16px; }
.aa-dark-card   { flex:1; background:rgba(255,255,255,0.08); border-radius:12px; padding:22px 24px; display:flex; flex-direction:column; gap:10px; overflow:hidden; }
.aa-dark-label  { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600; color:rgba(255,255,255,0.5); margin:0; line-height:1.3; }
.aa-dark-body   { font-family:'DM Sans',sans-serif; font-size:15px; color:rgba(255,255,255,0.85); margin:0; line-height:1.55; }
.aa-slide .confidential { color:rgba(255,255,255,0.45); }

/* ── LS1 · Pitfalls (pf-) ────────────────────────────────────────────────── */
.pf-slide           { padding-bottom:0; }
.pf-subhead         { font-size:17px; color:#78716c; margin:2px 0 16px; flex-shrink:0; }
.pf-grid            { display:grid; grid-template-columns:repeat(5,1fr); gap:10px; flex:1; align-content:stretch; }
.pf-card            { border-radius:12px; padding:18px 14px; text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; opacity:0; transform:translateY(12px); transition:opacity 0.4s ease, transform 0.4s ease; }
.pf-icon            { font-size:26px; }
.pf-title           { font-size:14px; font-weight:700; line-height:1.3; margin:0; }
.pf-desc            { font-size:12px; color:#a8a29e; line-height:1.4; margin:0; }
.pf-group-amber .pf-title { color:#b45309; }
.pf-group-red   .pf-title { color:#dc2626; }
.pf-group-blue  .pf-title { color:#1d4ed8; }
.pf-legend          { display:flex; gap:20px; justify-content:center; font-size:13px; color:#78716c; padding:10px 0 0; flex-shrink:0; }
.pf-legend-item     { display:flex; align-items:center; gap:6px; }
.pf-legend-dot      { width:10px; height:10px; border-radius:3px; display:inline-block; }

/* ── LS2 · What We've Heard (wh-) ───────────────────────────────────────── */
.wh-slide           { background:#1c1917; display:flex; flex-direction:column; padding:40px 60px 0; }
.wh-slide .eyebrow  { color:#fb923c; }
.wh-stakeholders    { font-size:15px; color:rgba(255,255,255,0.35); margin:2px 0 16px; flex-shrink:0; }
.wh-body            { display:grid; grid-template-columns:210px 1fr; gap:28px; flex:1; min-height:0; align-items:stretch; padding-bottom:12px; }
.wh-stat-col        { display:flex; flex-direction:column; align-items:center; }
.wh-gauge           { position:relative; width:200px; height:200px; flex-shrink:0; }
.wh-gauge-center    { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; width:140px; }
.wh-stat-num        { font-family:'DM Serif Display',serif; font-size:52px; color:#fb923c; line-height:1; }
.wh-stat-lbl        { font-size:13px; color:rgba(255,255,255,0.5); margin-top:6px; line-height:1.3; }
.wh-stat-ctx        { font-size:13px; color:rgba(255,255,255,0.38); line-height:1.5; text-align:center; margin-top:14px; }
.wh-signals         { display:flex; flex-direction:column; gap:12px; }
.wh-s1              { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-left:3px solid #fb923c; border-radius:0 12px 12px 0; padding:18px 22px; flex-shrink:0; }
.wh-s1-lbl          { font-size:12px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#fb923c; margin:0 0 8px; }
.wh-s1-quote        { font-family:'DM Serif Display',serif; font-size:21px; color:#fff; line-height:1.3; font-style:italic; margin:0 0 6px; }
.wh-s1-src          { font-size:13px; color:rgba(255,255,255,0.35); margin:0; }
.wh-s23             { display:grid; grid-template-columns:1fr 1fr; gap:12px; flex-shrink:0; }
.wh-sc              { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:16px 18px; }
.wh-sc-lbl          { font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#fb923c; margin:0 0 8px; }
.wh-sc-title        { font-size:17px; font-weight:700; color:#fff; margin:0 0 5px; line-height:1.3; }
.wh-sc-desc         { font-size:15px; color:rgba(255,255,255,0.5); line-height:1.5; margin:0; }
.wh-q2              { background:rgba(255,255,255,0.03); border-radius:10px; padding:14px 18px; flex:1; display:flex; flex-direction:column; justify-content:center; }
.wh-q2-text         { font-size:16px; color:rgba(255,255,255,0.55); font-style:italic; line-height:1.5; margin:0; }
.wh-q2-src          { font-size:13px; color:rgba(255,255,255,0.3); margin:6px 0 0; }
.wh-slide .confidential { color:rgba(255,255,255,0.35); }

/* ── LS23 · Case Study / GOAT Story (cs-) ───────────────────────────────── */
.cs-slide               { display:flex; flex-direction:column; padding-bottom:0; }
.cs-cols                { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; flex:1; min-height:0; }
.cs-col-label           { font-size:12px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a8a29e; margin:0 0 10px; }
.cs-badge-row           { display:flex; align-items:center; gap:8px; margin-bottom:8px; }
.cs-badge               { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; color:#fff; font-family:'DM Serif Display',serif; font-size:16px; font-weight:700; flex-shrink:0; }
.cs-badge.g             { background:#c2410c; }
.cs-badge.o             { background:#dc2626; }
.cs-badge.a             { background:#b45309; }
.cs-badge-label         { font-size:13px; font-weight:700; }
.cs-badge-label.g       { color:#c2410c; }
.cs-badge-label.o       { color:#dc2626; }
.cs-badge-label.a       { color:#b45309; }
/* G card */
.cs-g-card              { background:#fff7ed; border:1px solid #fed7aa; border-radius:12px; padding:20px; margin-bottom:12px; }
.cs-g-text              { font-family:'DM Serif Display',serif; font-size:20px; color:#1c1917; line-height:1.3; margin:0; }
/* O card */
.cs-o-card              { background:#fef2f2; border:1px solid #fecaca; border-radius:12px; padding:20px; }
.cs-o-bullet            { font-size:14px; color:#1c1917; line-height:1.7; margin:0; }
/* A card */
.cs-a-card              { background:#fffbeb; border:1px solid #fde68a; border-radius:12px; padding:20px; }
.cs-agents-list         { display:flex; flex-direction:column; gap:8px; margin-top:12px; }
.cs-agent-item          { background:#fff; border:1px solid #fde68a; border-radius:8px; padding:10px 14px; font-size:13px; color:#1c1917; }
.cs-agent-num           { color:#b45309; font-weight:700; }
/* T column */
.cs-t-metric            { background:#16a34a; border-radius:12px; padding:16px 20px; text-align:center; margin-bottom:10px; }
.cs-t-metric-num        { font-family:'DM Serif Display',serif; font-size:52px; color:#fff; line-height:1; }
.cs-t-metric-lbl        { font-size:15px; font-weight:600; color:rgba(255,255,255,0.85); margin-top:4px; }
.cs-t-card              { background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:14px 16px; margin-bottom:8px; }
.cs-t-card-label        { font-size:11px; font-weight:700; letter-spacing:0.06em; color:#16a34a; margin:0 0 4px; }
.cs-t-card-body         { font-size:14px; color:#1c1917; line-height:1.45; margin:0; }
/* Insight bar — uses shared .takeaway-box */

/* ── LS4 · Metrics Deep-Dive (md-) ─────────────────────────────────────── */
.md-slide               { display:flex; flex-direction:column; padding-bottom:0; }
.md-context             { font-size:15px; color:#78716c; margin:2px 0 20px; flex-shrink:0; }
.md-body                { display:grid; grid-template-columns:1fr 340px; gap:24px; flex:1; min-height:0; align-items:stretch; padding-bottom:0; }
.md-metrics             { display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; gap:16px; }
.md-metric-card         { background:#fff; border:1px solid #e7dfd7; border-radius:14px; padding:22px 22px 18px; display:flex; flex-direction:column; }
.md-metric-num          { font-family:'DM Serif Display',serif; font-size:44px; line-height:1; color:#c2410c; letter-spacing:-0.02em; }
.md-metric-delta        { font-size:13px; font-weight:600; color:#16a34a; margin:4px 0 10px; }
.md-metric-title        { font-size:16px; font-weight:700; color:#1c1917; margin:0 0 5px; line-height:1.3; }
.md-metric-desc         { font-size:14px; color:#78716c; line-height:1.5; margin:0; flex:1; }
.md-narrative           { display:flex; flex-direction:column; gap:14px; padding-bottom:12px; }
.md-narr-header         { font-size:17px; font-weight:700; color:#1c1917; margin:0; }
.md-narr-point          { display:flex; gap:10px; align-items:flex-start; }
.md-narr-dot            { width:8px; height:8px; border-radius:50%; background:#c2410c; flex-shrink:0; margin-top:6px; }
.md-narr-text           { font-size:15px; color:#78716c; line-height:1.6; margin:0; }
.md-narr-quote          { background:#fffbf7; border-left:3px solid #c2410c; padding:14px 16px; border-radius:0 10px 10px 0; margin-top:auto; }
.md-narr-quote-text     { font-size:15px; font-style:italic; color:#44403c; line-height:1.5; margin:0 0 6px; }
.md-narr-quote-src      { font-size:13px; color:#a8a29e; margin:0; }

/* ── LS5 · Survey Insights (si-) ────────────────────────────────────────── */
.si-slide               { display:flex; flex-direction:column; padding-bottom:0; }
.si-context             { font-size:15px; color:#78716c; margin:2px 0 20px; flex-shrink:0; }
.si-body                { display:grid; grid-template-columns:260px 1fr; gap:24px; flex:1; min-height:0; align-items:stretch; padding-bottom:0; }
.si-stat-col            { display:flex; flex-direction:column; gap:0; }
.si-stat-card           { background:#fff7ed; border:1px solid #fed7aa; border-radius:14px 14px 0 0; padding:28px 24px 22px; flex-shrink:0; }
.si-stat-num            { font-family:'DM Serif Display',serif; font-size:56px; color:#c2410c; line-height:1; letter-spacing:-0.02em; }
.si-stat-lbl            { font-size:14px; font-weight:600; color:#c2410c; margin:6px 0 0; line-height:1.3; }
.si-stat-src            { font-size:12px; color:#a8a29e; margin-top:6px; }
.si-stat-extra          { background:#fff; border:1px solid #e7dfd7; border-top:none; border-radius:0 0 14px 14px; padding:16px 20px; flex:1; }
.si-stat-extra-title    { font-size:15px; font-weight:700; color:#1c1917; margin:0 0 6px; }
.si-stat-extra-desc     { font-size:14px; color:#78716c; line-height:1.55; margin:0; }
.si-findings            { display:flex; flex-direction:column; gap:14px; padding-bottom:12px; }
.si-finding             { background:#fff; border:1px solid #e7dfd7; border-radius:12px; padding:16px 20px; display:flex; gap:14px; align-items:flex-start; flex:1; }
.si-finding-num         { font-family:'DM Serif Display',serif; font-size:28px; color:#e7dfd7; line-height:1; flex-shrink:0; width:28px; }
.si-finding-body        { flex:1; }
.si-finding-title       { font-size:16px; font-weight:700; color:#1c1917; margin:0 0 4px; line-height:1.3; }
.si-finding-desc        { font-size:15px; color:#78716c; line-height:1.5; margin:0; }

/* ── LS66 · Commit Canvas (cc-) ─────────────────────────────────────────── */
.cc-slide               { background:#f5f0eb; display:flex; flex-direction:column; padding:24px 60px 0; }
.cc-slide .eyebrow      { text-align:center; }
.cc-headline            { text-align:center; margin-bottom:14px !important; }
.cc-canvas              { background:#fff; border:1px solid #d6d0c8; border-radius:4px; box-shadow:2px 3px 12px rgba(0,0,0,0.08); overflow:hidden; flex:1; display:flex; flex-direction:column; min-height:0; }
.cc-canvas-header       { display:flex; justify-content:space-between; align-items:center; padding:10px 24px; border-bottom:2px solid #1c1917; flex-shrink:0; }
.cc-canvas-title        { font-family:'DM Serif Display',serif; font-size:17px; color:#1c1917; }
.cc-fill-fields         { display:flex; gap:20px; }
.cc-fill-field          { border-bottom:1px solid #ccc; min-width:90px; font-size:13px; color:#aaa; padding-bottom:2px; }
.cc-section-header      { padding:8px 24px 6px; border-bottom:1px solid #e5e0d8; flex-shrink:0; }
.cc-section-header.a    { background:#fef6ee; }
.cc-section-header.b    { background:#f0fdf4; }
.cc-section-label       { font-size:12px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; }
.cc-section-header.a .cc-section-label { color:#c2410c; }
.cc-section-header.b .cc-section-label { color:#16a34a; }
.cc-row                 { display:grid; grid-template-columns:46px 1fr 1.2fr; border-bottom:1px solid #e5e0d8; flex-shrink:0; flex:1; }
.cc-row-num             { color:#fff; display:flex; align-items:center; justify-content:center; font-family:'DM Serif Display',serif; font-size:20px; }
.cc-row-num.a           { background:#c2410c; }
.cc-row-num.b           { background:#16a34a; }
.cc-row-left            { padding:12px 16px; border-right:1px solid #e5e0d8; }
.cc-row-right           { padding:12px 16px; }
.cc-row-label           { font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; margin:0 0 3px; }
.cc-row-left .cc-row-label.a  { color:#c2410c; }
.cc-row-left .cc-row-label.b  { color:#16a34a; }
.cc-row-right .cc-row-label   { color:#a8a29e; }
.cc-row-prompt          { font-size:13px; color:#1c1917; line-height:1.4; margin:0; }
.cc-row-blank           { font-size:12px; color:#a8a29e; font-style:italic; margin:0; }
.cc-footer-bar          { display:grid; grid-template-columns:repeat(3,1fr); background:#1c1917; padding:10px 20px; flex:1; align-items:center; min-height:0; }
.cc-footer-col          { text-align:center; padding:4px 8px; }
.cc-footer-col:not(:last-child) { border-right:1px solid rgba(255,255,255,0.1); }
.cc-footer-col-label    { font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#fb923c; margin:0 0 2px; }
.cc-footer-col-sub      { font-size:11px; color:rgba(255,255,255,0.4); margin:0; }

/* ── LS7 · Slido Embed (sl-) ────────────────────────────────────────────── */
.sl-slide               { background:#1c1917; display:flex; flex-direction:column; padding:0; }
.sl-iframe              { flex:1; width:100%; border:none; display:block; }

/* ── LS24 · Agent Pipeline (ap-) ─────────────────────────────────────────── */
.ap-slide           { display:flex; flex-direction:column; padding-bottom:0; }
.ap-agents          { display:flex; gap:8px; flex-shrink:0; margin-bottom:12px; }
.ap-agent-card      { flex:1; background:#fff; border:1px solid #e7dfd7; border-top:3px solid #f59e0b; border-radius:0 0 10px 10px; padding:14px; }
.ap-agent-label     { font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#f59e0b; margin:0 0 6px; }
.ap-agent-desc      { font-size:13px; color:#78716c; line-height:1.5; margin:0; }
.ap-bottom          { display:flex; gap:18px; flex:1; min-height:0; }
.ap-screenshot      { width:230px; border-radius:12px; border:1px solid #e7dfd7; object-fit:cover; flex-shrink:0; align-self:center; }
.ap-right           { flex:1; display:flex; flex-direction:column; gap:12px; }
.ap-flow            { display:flex; gap:5px; align-items:center; flex-wrap:wrap; }
.ap-flow-step       { background:#fff; border:1px solid #e7dfd7; border-radius:8px; padding:6px 12px; font-size:13px; font-weight:600; color:#1c1917; }
.ap-flow-step.human { background:#fff7ed; border:2px solid #c2410c; color:#c2410c; font-weight:700; }
.ap-flow-arrow      { color:#f59e0b; font-size:14px; flex-shrink:0; }
.ap-principle       { flex:1; padding:14px 18px; background:#fffbf7; border:1px solid #e7dfd7; border-radius:10px; font-size:14px; color:#1c1917; line-height:1.55; }

/* ── LS26 · SIP Deep-Dive (sd-) ──────────────────────────────────────────── */
.sd-slide           { display:flex; flex-direction:column; padding-bottom:0; }
.sd-cols            { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; flex-shrink:0; margin-bottom:12px; }
.sd-core            { background:#1c1917; border-radius:14px; padding:18px; }
.sd-core-label      { font-size:12px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#fb923c; margin:0 0 6px; }
.sd-core-title      { font-family:'DM Serif Display',serif; font-size:22px; color:#fff; margin:0 0 8px; }
.sd-core-desc       { font-size:14px; color:rgba(255,255,255,0.6); line-height:1.5; margin:0 0 8px; }
.sd-core-meta       { font-size:12px; color:rgba(255,255,255,0.35); margin:0; }
.sd-agent-card      { background:#fff; border:1px solid #e7dfd7; border-top:3px solid #f59e0b; border-radius:0 0 14px 14px; padding:18px; }
.sd-agent-label     { font-size:12px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#f59e0b; margin:0 0 8px; }
.sd-screenshots     { display:flex; gap:14px; justify-content:center; flex:1; min-height:0; overflow:hidden; }
.sd-screenshot      { max-height:100%; width:auto; border-radius:10px; border:1px solid #e7dfd7; object-fit:contain; }

/* ── LS29 · Pipeline Comparison (pc-) ────────────────────────────────────── */
.pc-slide           { display:flex; flex-direction:column; padding-bottom:0; gap:8px; }
.pc-section-label   { font-size:12px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; margin:0 0 6px; flex-shrink:0; }
.pc-section-label.asis { color:#dc2626; }
.pc-section-label.tobe { color:#16a34a; }
.pc-row             { display:flex; gap:4px; align-items:stretch; flex-shrink:0; }
.pc-step            { flex:1; border-radius:10px; padding:10px 12px; text-align:center; }
.pc-step.asis       { background:#fef2f2; border:1px solid #fecaca; }
.pc-step.ai         { background:#f0fdf4; border:1px solid #bbf7d0; }
.pc-step.hitl       { background:#fffbeb; border:1px solid #fde68a; }
.pc-step.unchanged  { background:#fff;    border:1px solid #e7dfd7; }
.pc-step-stage      { font-size:14px; font-weight:700; color:#1c1917; margin:0 0 3px; }
.pc-step-sub        { font-size:12px; color:#dc2626; margin:0; }
.pc-badge           { font-size:11px; font-weight:700; border-radius:4px; padding:2px 7px; display:inline-block; margin:3px 0; }
.pc-badge.ai        { color:#16a34a; background:#dcfce7; }
.pc-badge.hitl      { color:#b45309; background:#fef3c7; }
.pc-step-desc       { font-size:11px; color:#78716c; margin:2px 0 0; }
.pc-arrow           { display:flex; align-items:center; font-size:13px; flex-shrink:0; }
.pc-arrow.asis      { color:#dc2626; }
.pc-arrow.tobe      { color:#16a34a; }
.pc-down-arrow      { text-align:center; font-size:20px; color:#c2410c; flex-shrink:0; line-height:1; }
.pc-bottom          { display:flex; gap:16px; align-items:center; flex-shrink:0; }
.pc-legend          { display:flex; gap:10px; font-size:12px; flex-shrink:0; white-space:nowrap; }
.pc-legend-dot      { width:10px; height:10px; border-radius:3px; flex-shrink:0; display:inline-block; margin-right:3px; vertical-align:middle; }
.pc-insight         { flex:1; padding:11px 16px; background:#f5f0eb; border:1px solid #e7dfd7; border-radius:10px; font-size:13px; color:#1c1917; line-height:1.5; }

/* ── LS30 · Frontier Case (fc-) ──────────────────────────────────────────── */
.fc-slide           { display:flex; flex-direction:column; padding:40px 60px 0; background:#1c1917; }
.fc-header          { text-align:center; margin-bottom:18px; flex-shrink:0; }
.fc-subhead         { font-size:15px; color:rgba(255,255,255,0.5); max-width:680px; margin:8px auto 0; line-height:1.6; }
.fc-body            { display:grid; grid-template-columns:240px 1fr; gap:24px; align-items:center; flex:1; min-height:0; }
.fc-image           { width:240px; border-radius:12px; border:1px solid rgba(255,255,255,0.15); object-fit:cover; }
.fc-right           { display:flex; flex-direction:column; gap:12px; }
.fc-company         { font-family:'DM Serif Display',serif; font-size:26px; color:#fff; margin:0; line-height:1.3; }
.fc-para            { font-size:15px; color:rgba(255,255,255,0.7); line-height:1.6; margin:0; }
.fc-insight-box     { background:rgba(251,146,60,0.15); border:1px solid rgba(251,146,60,0.3); border-radius:10px; padding:14px 18px; }
.fc-insight-text    { font-size:15px; color:rgba(255,255,255,0.85); line-height:1.55; margin:0; }

/* ── GCC Solutions Overview (gs-) ────────────────────────────────────────── */
.gs-slide          { background:#fffbf7; display:flex; flex-direction:column; padding:40px 60px 0; }
.gs-header         { margin-bottom:16px; flex-shrink:0; }
.gs-cols           { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; flex:1; min-height:0; }
.gs-col            { display:flex; flex-direction:column; border-radius:12px; overflow:hidden; border:1.5px solid #e7dfd7; }
.gs-col--highlight { border-color:#c2410c; border-width:2.5px; box-shadow:0 0 0 3px rgba(194,65,12,0.12); }
.gs-col--dim       { opacity:0.35; }
.gs-col-num        { display:inline-flex; width:22px; height:22px; border-radius:50%; background:rgba(255,255,255,0.22); color:#fff; font-size:12px; font-weight:700; align-items:center; justify-content:center; margin-bottom:8px; }
.gs-col-hdr        { padding:14px 18px 12px; flex-shrink:0; }
.gs-col-title      { font-size:15px; font-weight:700; color:#fff; margin-bottom:4px; line-height:1.2; }
.gs-col-sublabel   { font-size:11px; font-weight:500; color:rgba(255,255,255,0.55); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
.gs-col-roles      { font-size:11px; font-weight:400; color:rgba(255,255,255,0.65); line-height:1.55; margin:0; }
.gs-col-body       { flex:1; display:flex; flex-direction:column; gap:10px; padding:14px; background:#fff; }
.gs-prog-card      { flex:1; border-radius:8px; padding:12px 14px; background:#f5f0eb; display:flex; flex-direction:column; }
.gs-prog-top       { flex:1; display:flex; flex-direction:column; gap:4px; margin-bottom:8px; }
.gs-prog-name      { font-size:12px; font-weight:700; color:#1c1917; line-height:1.3; margin:0; }
.gs-prog-tagline   { font-size:11px; font-weight:600; color:#c2410c; line-height:1.3; margin:0; }
.gs-prog-desc      { font-size:10px; font-weight:400; color:#78716c; line-height:1.45; margin:0; }
.gs-prog-pills     { display:flex; flex-wrap:wrap; gap:5px; align-items:center; flex-shrink:0; }
.gs-prog-tag       { display:inline-block; font-size:10px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:3px 10px; border-radius:100px; }
.gs-prog-tag--acc  { background:rgba(194,65,12,0.10); color:#c2410c; }
.gs-prog-tag--acad { background:rgba(30,58,138,0.10); color:#1e3a8a; }
.gs-prog-dur       { display:inline-block; font-size:10px; font-weight:500; letter-spacing:0.04em; padding:3px 9px; border-radius:100px; background:rgba(28,25,23,0.07); color:#57534e; }

/* ── Approach Points (ap-) ───────────────────────────────────────────────── */
.ap-slide    { }
.ap-header   { margin-bottom:18px; flex-shrink:0; }
.ap-grid     { display:grid; grid-template-columns:1fr 1fr; column-gap:54px; row-gap:22px; align-content:center; flex:1; padding-top:20px; }
.ap-item     { display:flex; gap:16px; align-items:flex-start; }
.ap-num-col  { display:flex; flex-direction:column; align-items:center; gap:5px; flex-shrink:0; width:36px; }
.ap-icon     { width:30px; height:30px; border-radius:8px; background:rgba(194,65,12,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.ap-icon svg { width:16px; height:16px; stroke:#c2410c; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
.ap-num      { font-family:'DM Serif Display',serif; font-size:22px; color:#c2410c; line-height:1; }
.ap-content  { flex:1; }
.ap-title    { font-size:14px; font-weight:700; color:#1c1917; margin:0 0 5px; line-height:1.3; }
.ap-desc     { font-size:12px; font-weight:400; color:#78716c; margin:0; line-height:1.6; }

/* ── Testimonials Grid (tg-) ─────────────────────────────────────────────── */
.tg-slide   { }
.tg-grid    { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; flex:1; min-height:0; }
.tg-card    { background:#f5f0eb; border-radius:8px; padding:12px 14px; display:flex; flex-direction:column; }
.tg-quote   { font-size:11px; font-style:italic; color:#44403c; line-height:1.6; flex:1; margin:0 0 8px; }
.tg-attr    { flex-shrink:0; border-top:1px solid rgba(28,25,23,0.10); padding-top:7px; }
.tg-role    { font-size:10px; font-weight:700; color:#1c1917; margin:0; line-height:1.4; }
.tg-company { font-size:10px; font-weight:400; color:#a8a29e; margin:0; line-height:1.4; }
.gs-legend         { font-size:11px; font-weight:500; color:#a8a29e; text-align:center; letter-spacing:0.04em; flex-shrink:0; padding:10px 0 8px; }
.gs-legend-dot     { display:inline-block; width:7px; height:7px; border-radius:100px; margin-right:5px; vertical-align:middle; }

/* ── gcc_solutions 2-row layout (gs2-) ──────────────────────────────────── */
.gs2-body       { flex:1; display:flex; flex-direction:column; gap:10px; min-height:0; }
.gs2-row        { flex:1; display:flex; gap:14px; min-height:0; }
.gs2-row .gs-col { flex:1; }

/* ── IK GCC Landscape (igcc-) ───────────────────────────────────────────────  */
.igcc-slide        { }
.igcc-body         { flex:1; display:flex; flex-direction:column; justify-content:center; }
.igcc-cols         { display:flex; gap:20px; }
.igcc-card         { flex:1; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:14px; padding:22px 26px; display:flex; flex-direction:column; }
.igcc-pill         { display:inline-block; font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:5px 14px; border-radius:100px; align-self:flex-start; margin-bottom:14px; }
.igcc-pill--opp    { background:#052e16; color:#4ade80; }
.igcc-pill--prs    { background:#2a1a06; color:#fb923c; }
.igcc-item         { display:flex; flex-direction:column; gap:5px; padding:14px 0; }
.igcc-item--border { border-top:1px solid rgba(255,255,255,0.08); }
.igcc-gist         { font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#ffffff; line-height:1.4; margin:0; }
.igcc-meta         { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:400; color:rgba(255,255,255,0.4); line-height:1.4; margin:0; }

/* ── IK Capstone Tracks (ict-) ──────────────────────────────────────────────  */
.ict-slide        { }
.ict-body         { flex:1; display:flex; flex-direction:column; justify-content:center; gap:20px; }
.ict-cards        { display:flex; gap:20px; }
.ict-card         { flex:1; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:24px 28px; display:flex; flex-direction:column; gap:16px; }
.ict-pill         { display:inline-block; font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:5px 14px; border-radius:100px; align-self:flex-start; }
.ict-pill--a      { background:#162032; color:#93c5fd; }
.ict-pill--b      { background:#2a1a06; color:#fed7aa; }
.ict-card-title   { font-family:'DM Sans',sans-serif; font-size:22px; font-weight:700; color:#ffffff; line-height:1.25; margin:0; }
.ict-items        { display:flex; flex-direction:column; gap:12px; flex:1; }
.ict-item-text    { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:rgba(255,255,255,0.72); line-height:1.45; margin:0; }
.ict-functions    { display:flex; align-items:center; gap:20px; flex-shrink:0; padding-top:16px; border-top:1px solid rgba(255,255,255,0.1); }
.ict-fn-label     { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; color:#c2410c; letter-spacing:0.12em; text-transform:uppercase; flex-shrink:0; }
.ict-fn-text      { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:#fb923c; margin:0; }

/* ── IK Program Curriculum (ipc-) ─────────────────────────────────────────── */
.ipc-slide         { }
.ipc-table         { flex:1; min-height:0; border:1px solid rgba(255,255,255,0.1); border-radius:10px; overflow:hidden; display:flex; flex-direction:column; }
.ipc-col-headers   { display:flex; flex-shrink:0; padding:7px 0; border-bottom:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.03); align-items:center; }
.ipc-hdr-text      { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:700; color:rgba(255,255,255,0.35); letter-spacing:0.1em; text-transform:uppercase; }
.ipc-hdr-ship      { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:3px 10px; border-radius:4px; }
.ipc-ship-hdr-cell { border-left:0 !important; background:transparent !important; justify-content:flex-start; }
.ipc-rows          { flex:1; display:flex; flex-direction:column; min-height:0; }
.ipc-row           { display:flex; flex:1; min-height:0; align-items:stretch; }
.ipc-row--border   { border-bottom:1px solid rgba(255,255,255,0.07); }
.ipc-col-wk        { width:52px; flex-shrink:0; display:flex; align-items:center; justify-content:center; padding:0 6px; }
.ipc-col-theme     { width:185px; flex-shrink:0; display:flex; flex-direction:column; justify-content:center; padding:8px 14px; border-right:1px solid rgba(255,255,255,0.07); }
.ipc-col-do        { flex:1; display:flex; align-items:center; padding:8px 16px; border-right:1px solid rgba(255,255,255,0.07); }
.ipc-col-ship      { width:340px; flex-shrink:0; display:flex; flex-direction:column; justify-content:center; padding:8px 16px; border-left:3px solid; background:rgba(255,255,255,0.03); }
.ipc-num           { font-family:'DM Serif Display',Georgia,serif; font-size:22px; font-weight:400; color:#c2410c; line-height:1; margin:0; }
.ipc-theme-name    { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:700; color:#fffbf7; line-height:1.2; margin:0 0 3px; }
.ipc-theme-sub     { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:400; color:rgba(255,255,255,0.42); line-height:1.3; margin:0; }
.ipc-col-do p      { font-family:'DM Sans',sans-serif; font-size:12px; font-weight:400; color:rgba(255,255,255,0.68); line-height:1.45; margin:0; }
.ipc-ship-label    { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 4px; }
.ipc-ship-text     { font-family:'DM Sans',sans-serif; font-size:12px; font-weight:400; color:rgba(255,255,255,0.82); line-height:1.35; margin:0; }

/* ── IK Program Rows (ikr-) ──────────────────────────────────────────────── */
.ikr-body         { flex:1; display:flex; flex-direction:column; justify-content:center; }
.ikr-row          { display:flex; align-items:center; gap:28px; padding:13px 0; border-bottom:1px solid rgba(255,255,255,0.08); }
.ikr-row:last-child { border-bottom:none; }
.ikr-label        { width:148px; flex-shrink:0; }
.ikr-pill         { display:inline-block; font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; color:#fff; letter-spacing:0.1em; text-transform:uppercase; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.18); padding:4px 12px; border-radius:100px; }
.ikr-value        { flex:1; font-family:'DM Sans',sans-serif; font-size:17px; font-weight:500; color:#fffbf7; line-height:1.3; margin:0; }

/* ── Acceler Approach (aap-) ─────────────────────────────────────────────── */
.aap-slide         { display:flex; flex-direction:column; }
.aap-body          { flex:1; display:flex; gap:20px; min-height:0; }
.aap-left          { flex:1.6; display:flex; flex-direction:column; min-width:0; overflow:visible; margin-top:10px; }
.aap-left-hdr      { background:#1c1917; border-radius:8px; padding:12px 20px; flex-shrink:0; text-align:center; }
.aap-left-donut    { flex:1; display:flex; align-items:center; justify-content:center; overflow:visible; }
.aap-right         { flex:1; display:flex; flex-direction:column; margin-top:10px; margin-bottom:10px; }
.aap-box           { flex:1; display:flex; flex-direction:column; border-radius:10px; overflow:hidden; border:1.5px solid #e7e5e4; }
.aap-box-hdr       { background:#1c1917; padding:12px 20px; flex-shrink:0; }
.aap-box-title     { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; color:#fff; margin:0; }
.aap-box-body      { flex:1; background:#fafaf9; padding:14px 18px; display:flex; flex-direction:column; }
.aap-box-items     { flex:1; display:flex; flex-direction:column; gap:7px; }
.aap-box-item-ttl  { font-family:'DM Sans',sans-serif; font-size:12px; font-weight:700; color:#1c1917; margin:0 0 2px; }
.aap-box-item-desc { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:400; color:#57534e; margin:0; line-height:1.4; }
.aap-box-tkwy      { background:#1c1917; border-radius:6px; padding:8px 12px; margin-top:8px; flex-shrink:0; }
.aap-box-tkwy p    { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:500; color:#fff; margin:0; line-height:1.4; }
.aap-journey-wrap  { flex-shrink:0; margin-top:8px; }
.aap-journey-pills { display:flex; align-items:flex-start; gap:3px; }
.aap-stage-wrap    { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; }
.aap-pill          { display:block; font-family:'DM Sans',sans-serif; font-size:9px; font-weight:700; color:#fff; background:#1e3a8a; padding:5px 5px; border-radius:5px; text-align:center; line-height:1.3; width:100%; box-sizing:border-box; }
.aap-pill--hl      { background:#c2410c; }
.aap-week          { font-family:'DM Sans',sans-serif; font-size:8px; font-weight:500; color:#78716c; text-align:center; }
.aap-arr           { font-family:'DM Sans',sans-serif; font-size:13px; color:#a8a29e; flex-shrink:0; padding-top:5px; }
.aap-arrow-track   { display:flex; align-items:center; margin-top:3px; }
.aap-arrow-line    { flex:1; height:1.5px; background:#94a3b8; }
.aap-arrow-head    { width:0; height:0; border-top:4px solid transparent; border-bottom:4px solid transparent; border-left:7px solid #94a3b8; }

/* ── Two Cards (tc-) ────────────────────────────────────────────────────── */
.tc-slide      { display:flex; flex-direction:column; }
.tc-body-wrap  { flex:1; display:flex; flex-direction:column; justify-content:center; padding:8px 0; }
.tc-cards      { display:flex; gap:24px; }
.tc-card       { flex:1; display:flex; flex-direction:column; border-radius:10px; overflow:hidden; border:1.5px solid #e7e5e4; }
.tc-card--highlight { border-color:#c2410c; border-width:2.5px; box-shadow:0 0 0 3px rgba(194,65,12,0.12); }
.tc-card--dim  { opacity:0.45; }
.tc-card-body  { background:#f5f0eb; padding:18px 24px; display:flex; flex-direction:column; gap:9px; }
.tc-bullet     { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:#1c1917; line-height:1.5; margin:0; padding-left:18px; position:relative; }
.tc-bullet::before { content:'—'; position:absolute; left:0; color:#c2410c; font-weight:700; }

/* ── Agentic Fest (af) ──────────────────────────────────────────────────────── */
.af-statement { font-size:17px; font-weight:600; text-align:center; color:#1c1917; margin:8px 0 14px; line-height:1.4; flex-shrink:0; }
.af-cards     { display:flex; gap:14px; flex:1; margin-bottom:14px; min-height:0; }
.af-card      { flex:1; display:flex; flex-direction:column; border-radius:8px; overflow:hidden; border:1px solid #e2d9c8; }
.af-card-body { flex:1; padding:14px 16px; background:#f5f0eb; }
.af-card-desc { font-size:14px; color:#44403c; line-height:1.55; margin:0; }

/* ── Agentic Fest Visual (afv) ──────────────────────────────────────────────── */
.afv-body  { flex:1; display:flex; align-items:center; justify-content:center; }
.afv-flow  { display:flex; align-items:stretch; gap:0; }
.afv-step  { width:230px; flex-shrink:0; display:flex; flex-direction:column; align-items:center; text-align:center;
             background:#fff; border:1.5px solid #e2d9c8; border-top:3px solid #c2410c;
             border-radius:10px; padding:22px 18px 20px; gap:10px; }
.afv-emoji { font-size:44px; line-height:1; }
.afv-title { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; color:#1c1917; margin:0; line-height:1.3; }
.afv-desc  { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:400; color:#57534e; margin:0; line-height:1.45; }
.afv-arrow { font-size:22px; color:#c2410c; font-weight:700; flex-shrink:0; padding:0 10px; align-self:center; }

/* ── Pricing Grid (pg) ──────────────────────────────────────────────────────── */
.pg-body        { flex:1; display:flex; flex-direction:column; gap:12px; min-height:0; }
.pg-row         { display:flex; gap:14px; flex:1; min-height:0; }
.pg-card        { flex:1; display:flex; flex-direction:column; border-radius:8px; overflow:hidden; border:1px solid #e2d9c8; }
.pg-card-hdr    { padding:10px 14px; flex-shrink:0; }
.pg-card-name   { font-size:13px; font-weight:700; color:#fff; margin:0; line-height:1.3; }
.pg-card-cohort { font-size:10px; color:rgba(255,255,255,0.75); margin:3px 0 0; }
.pg-card-body   { padding:10px 14px; background:#fff; flex:1; display:flex; flex-direction:column; gap:8px; }
.pg-price-table  { display:flex; flex-direction:column; border:1px solid #ede9e3; border-radius:6px; overflow:hidden; }
.pg-ptr          { display:flex; justify-content:space-between; align-items:center; padding:6px 10px; background:#fafaf9; }
.pg-ptr--disc    { background:#f0fdf4; border-top:1px solid #ede9e3; }
.pg-ptr--final   { background:#fff8f5; border-top:1px solid #ede9e3; }
.pg-plabel       { font-size:12px; color:#78716c; }
.pg-plabel--disc { font-size:12px; font-weight:600; color:#15803d; }
.pg-plabel--final { font-size:12px; font-weight:600; color:#c2410c; }
.pg-orig         { font-size:20px; font-weight:700; color:#1c1917; line-height:1; }
.pg-discount     { font-size:20px; font-weight:700; color:#16a34a; line-height:1; }
.pg-price        { font-size:20px; font-weight:700; color:#c2410c; line-height:1; }
.pg-pills       { display:flex; flex-wrap:wrap; gap:4px; }
.pg-pill        { font-size:10px; font-weight:600; color:#fff; padding:3px 10px; border-radius:100px; white-space:nowrap; letter-spacing:0.04em; }

/* ── IK Speaker Profile (iksp-) ─────────────────────────────────────────── */
.iksp-slide       { display:flex; flex-direction:column; }
.iksp-body        { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px; }
.iksp-profile     { display:flex; flex-direction:column; align-items:center; gap:6px; }
.iksp-photo-wrap  { width:150px; height:150px; border-radius:50%; overflow:hidden; border:3px solid #e7e5e4; }
.iksp-photo       { width:100%; height:100%; object-fit:cover; object-position:center top; }
.iksp-name        { font-family:'DM Serif Display',serif; font-size:22px; font-weight:400; color:#1c1917; margin:0; }
.iksp-role        { font-family:'DM Sans',sans-serif; font-size:14px; font-weight:400; color:#78716c; margin:0; text-align:center; }
.iksp-creds       { display:flex; flex-direction:column; gap:10px; width:600px; }
.iksp-cred        { background:#fff; border:1.5px solid #e7e5e4; border-radius:10px; padding:16px 22px; }
.iksp-cred-text   { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:500; color:#1c1917; margin:0; line-height:1.4; }

/* ── IK Capstone Grid (ikcg-) ───────────────────────────────────────────── */
.ikcg-body            { flex:1; display:grid; grid-template-columns:repeat(3,1fr); grid-template-rows:repeat(2,1fr); gap:12px; padding-top:8px; }
.ikcg-card            { background:#fff; border:1.5px solid #e7e5e4; border-radius:10px; padding:16px 18px; display:flex; flex-direction:column; gap:8px; }
.ikcg-func            { display:inline-block; font-family:'DM Sans',sans-serif; font-size:10px; font-weight:700; color:#fff; letter-spacing:0.1em; text-transform:uppercase; padding:3px 10px; border-radius:100px; align-self:flex-start; }
.ikcg-func--teal      { background:#0f766e; }
.ikcg-func--blue      { background:#1e40af; }
.ikcg-func--amber     { background:#b45309; }
.ikcg-func--charcoal  { background:#1c1917; }
.ikcg-func--navy      { background:#1e3a8a; }
.ikcg-func--orange    { background:#c2410c; }
.ikcg-title           { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; color:#1c1917; margin:0; line-height:1.3; }
.ikcg-desc            { font-family:'DM Sans',sans-serif; font-size:14px; font-weight:400; color:#57534e; margin:0; line-height:1.45; flex:1; }

/* ── IK Questions Grid (ikq-) ────────────────────────────────────────────── */
.ikq-body       { flex:1; display:flex; flex-direction:column; padding-top:10px; }
.ikq-grid       { display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; gap:10px; flex:1; }
.ikq-card       { display:flex; flex-direction:column; border-radius:8px; overflow:hidden; border:1px solid rgba(0,0,0,0.08); }
.ikq-card-hdr   { padding:9px 16px; flex-shrink:0; }
.ikq-card-title { font-family:'DM Sans',sans-serif; font-size:17px; font-weight:700; color:#fff; letter-spacing:0.04em; text-transform:uppercase; margin:0; }
.ikq-card-body  { flex:1; padding:10px 16px; display:flex; flex-direction:column; gap:5px; background:#ffffff; }
.ikq-question   { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:#44403c; line-height:1.4; margin:0; }

/* ── IK Partnership (ikpar-) ─────────────────────────────────────────────── */
.ikpar-body    { flex:1; display:flex; align-items:center; justify-content:center; }
.ikpar-logos   { display:flex; align-items:center; gap:56px; }
.ikpar-logo    { height:90px; width:auto; }
.ikpar-divider { width:1px; height:64px; background:rgba(0,0,0,0.1); flex-shrink:0; }

/* ── IK Three Steps (its-) ───────────────────────────────────────────────── */
.its-body    { flex:1; display:flex; align-items:center; }
.its-step    { flex:1; display:flex; flex-direction:column; align-items:center; text-align:center; padding:0 36px; }
.its-emoji   { font-size:52px; line-height:1; margin-bottom:18px; }
.its-name    { font-family:'DM Serif Display',Georgia,serif; font-size:56px; font-weight:400; color:#fffbf7; line-height:1; margin:0 0 22px; }
.its-chips   { display:flex; flex-wrap:wrap; gap:8px; justify-content:center; }
.its-chip    { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; color:rgba(255,255,255,0.6); padding:5px 14px; border:1px solid rgba(255,255,255,0.15); border-radius:100px; }
.its-arrow   { font-size:26px; color:rgba(255,255,255,0.2); flex-shrink:0; align-self:center; padding-bottom:44px; }

/* ── IK Pricing (ikp-) ────────────────────────────────────────────────────── */
.ikp-slide         { }
.ikp-body          { flex:1; display:flex; flex-direction:column; justify-content:center; padding-top:16px; }
.ikp-cols          { display:flex; gap:32px; align-items:stretch; }
.ikp-left          { flex:1; display:flex; flex-direction:column; gap:0; justify-content:center; }
.ikp-right         { width:340px; flex-shrink:0; display:flex; flex-direction:column; gap:0; border:1px solid rgba(255,255,255,0.12); border-radius:10px; overflow:hidden; }
.ikp-section-title { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; color:#c2410c; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 14px; }
.ikp-component     { display:flex; flex-direction:column; gap:4px; padding:12px 0; border-bottom:1px solid rgba(255,255,255,0.07); }
.ikp-component:last-child { border-bottom:none; }
.ikp-comp-title    { font-family:'DM Sans',sans-serif; font-size:17px; font-weight:600; color:#fffbf7; line-height:1.3; margin:0; }
.ikp-comp-sub      { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:rgba(255,255,255,0.55); line-height:1.4; margin:0; }
.ikp-row           { display:flex; flex-direction:column; gap:6px; padding:16px 20px; border-bottom:1px solid rgba(255,255,255,0.1); }
.ikp-row:last-child { border-bottom:none; }
.ikp-row--featured { background:#1e3a5f; }
.ikp-row-label     { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; color:rgba(255,255,255,0.45); letter-spacing:0.1em; text-transform:uppercase; margin:0; }
.ikp-row--featured .ikp-row-label { color:rgba(255,255,255,0.65); }
.ikp-row-amount    { font-family:'DM Serif Display',Georgia,serif; font-size:28px; font-weight:400; color:#fffbf7; line-height:1.1; margin:0; }
.ikp-row-amount span.ikp-gst { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:400; color:rgba(255,255,255,0.55); margin-left:4px; }
.ikp-row-discount  { font-family:'DM Serif Display',Georgia,serif; font-size:28px; font-weight:400; color:#f87171; line-height:1.1; margin:0; }
.ikp-row-note      { font-family:'DM Sans',sans-serif; font-size:12px; font-weight:400; color:rgba(255,255,255,0.5); line-height:1.3; margin:0; }
.ikp-row--featured .ikp-row-amount { color:#93c5fd; }
.ikp-right-title   { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; color:#c2410c; letter-spacing:0.12em; text-transform:uppercase; margin:0; padding:14px 20px 0; }
.ikp-row--info     { background:rgba(255,255,255,0.03); }
.ikp-row-info-text { font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:rgba(255,255,255,0.6); margin:0; }

/* Light variant overrides */
.ikp-light .ikp-right                         { border-color:rgba(0,0,0,0.1); }
.ikp-light .ikp-comp-title                    { color:#1c1917; }
.ikp-light .ikp-comp-sub                      { color:#6b7280; }
.ikp-light .ikp-component                     { border-bottom-color:rgba(0,0,0,0.07); }
.ikp-light .ikp-row                           { border-bottom-color:rgba(0,0,0,0.07); }
.ikp-light .ikp-row--featured                 { background:#eef2ff; }
.ikp-light .ikp-row-label                     { color:#9ca3af; }
.ikp-light .ikp-row--featured .ikp-row-label  { color:#4b5563; }
.ikp-light .ikp-row-amount                    { color:#1c1917; }
.ikp-light .ikp-row-amount span.ikp-gst       { color:#9ca3af; }
.ikp-light .ikp-row-discount                  { color:#dc2626; }
.ikp-light .ikp-row--featured .ikp-row-amount { color:#1e3a8a; }
.ikp-light .ikp-row-note                      { color:#9ca3af; }
.ikp-light .ikp-row--info                     { background:rgba(0,0,0,0.02); }
.ikp-light .ikp-row-info-text                 { color:#6b7280; }

/* ── Champions Timeline (cta-) ──────────────────────────────────────────── */
.cta-slide      { display:flex; flex-direction:column; }
.cta-body       { flex:1; display:flex; flex-direction:column; justify-content:center; gap:5px; position:relative; }
.cta-body::before { content:''; position:absolute; left:109px; top:14px; bottom:14px; width:2px; background:#e7e5e4; z-index:0; }
.cta-row        { display:flex; align-items:center; position:relative; z-index:1; }
.cta-week-col   { width:102px; flex-shrink:0; padding-right:14px; display:flex; flex-direction:column; align-items:flex-end; }
.cta-week-label { font-family:'DM Sans',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#9ca3af; text-align:right; line-height:1.2; }
.cta-dot        { width:10px; height:10px; border-radius:50%; background:#e7e5e4; border:2px solid #fffbf7; flex-shrink:0; margin-right:10px; }
.cta-module     { flex:1; display:flex; gap:0; align-items:stretch; background:#f5f0eb; border-radius:6px; overflow:hidden; }
.cta-mod-left   { width:240px; flex-shrink:0; padding:7px 12px; display:flex; flex-direction:column; gap:3px; border-right:1px solid rgba(0,0,0,0.08); }
.cta-mod-right  { flex:1; padding:7px 14px; display:flex; align-items:center; }
.cta-mod-name   { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; color:#1c1917; margin:0; line-height:1.25; }
.cta-mod-desc   { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:400; color:#6b7280; margin:0; line-height:1.4; }
.cta-pill       { display:inline-flex; align-items:center; padding:2px 8px; border-radius:3px; font-family:'DM Sans',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#fff; margin-bottom:3px; }
/* Pre-session */
.cta-row--pre .cta-week-label  { color:#c2410c; }
.cta-row--pre .cta-dot         { background:#c2410c; }
.cta-row--pre .cta-module      { background:#fff7ed; }
/* Agentic Fest */
.cta-row--fest .cta-week-label { color:#c2410c; }
.cta-row--fest .cta-dot        { background:#c2410c; width:12px; height:12px; }
.cta-row--fest .cta-module     { background:#1c1917; }
.cta-row--fest .cta-mod-left   { border-right-color:rgba(255,255,255,0.1); }
.cta-row--fest .cta-mod-name   { color:#fff; }
.cta-row--fest .cta-mod-desc   { color:rgba(255,255,255,0.7); }
/* Fest-light (non-capstone final row — orange dot, pill-colour background) */
.cta-row--fest-light .cta-week-label { color:#c2410c; }
.cta-row--fest-light .cta-dot        { background:#c2410c; width:12px; height:12px; }
/* Compact (7–8 row slides) */
.cta-slide--compact .headline        { font-size:26px; margin-bottom:8px; }
.cta-slide--compact .cta-body        { gap:3px; }
.cta-slide--compact .cta-mod-left    { padding:5px 10px; }
.cta-slide--compact .cta-mod-right   { padding:5px 12px; }
.cta-slide--compact .cta-mod-name    { font-size:13px; }
.cta-slide--compact .cta-mod-desc    { font-size:11px; }
/* Blueprint */
.cta-row--blueprint .cta-week-label { color:#1e3a8a; }
.cta-row--blueprint .cta-dot        { background:#1e3a8a; }
.cta-row--blueprint .cta-module     { background:#eff3ff; }
.cta-row--blueprint .cta-mod-name   { color:#1e3a8a; }

/* ── section_index ──────────────────────────────────────────────────────── */
.si-slide              { display:flex; flex-direction:column; }
.si-body               { flex:1; display:flex; flex-direction:column; justify-content:center; margin-top:16px; }
.si-cards              { display:flex; gap:20px; align-items:stretch; }
.si-card               { flex:1; display:flex; flex-direction:column; border:1px solid rgba(0,0,0,0.1); border-radius:10px; overflow:hidden; }
.si-card-body          { flex:1; padding:20px 24px; display:flex; flex-direction:column; }
.si-card-body--cover   { justify-content:center; }
.si-group-label        { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:600; color:#9ca3af; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 8px; }
.si-academy-item       { display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid rgba(0,0,0,0.07); }
.si-academy-dot        { font-size:14px; color:#c2410c; flex-shrink:0; line-height:1; }
.si-acc-list           { display:flex; flex-direction:column; }
.si-acc-item           { display:flex; align-items:center; gap:10px; padding:7px 0; border-bottom:1px solid rgba(0,0,0,0.07); }
.si-num                { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:700; color:#c2410c; width:16px; flex-shrink:0; text-align:center; }
.si-acc-name           { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:500; color:#1c1917; line-height:1.3; }
.si-cover-list         { display:flex; flex-direction:column; gap:28px; }
.si-cover-item         { display:flex; align-items:center; gap:16px; }
.si-cover-emoji        { font-size:28px; line-height:1; flex-shrink:0; }
.si-cover-label        { font-family:'DM Sans',sans-serif; font-size:18px; font-weight:600; color:#1c1917; white-space:nowrap; }
.si-item--hl           { border-left:3px solid #c2410c; padding-left:8px; background:rgba(194,65,12,0.05); border-radius:0 4px 4px 0; margin-left:-2px; }
.si-item--dim          { opacity:0.3; }

/* ── tech_modules_grid ────────────────────────────────────────────────────── */
.tmg-slide          { display:flex; flex-direction:column; }
.tmg-note           { font-size:12px; color:#78716c; font-style:italic; border-left:3px solid #c2410c; padding-left:10px; margin:2px 0 12px; line-height:1.5; flex-shrink:0; }
.tmg-grid           { flex:1; display:flex; gap:14px; min-height:0; }
.tmg-col            { flex:1; display:flex; flex-direction:column; gap:8px; min-width:0; }
.tmg-col-label      { font-size:11px; font-weight:700; color:#4A9DBF; text-transform:uppercase; letter-spacing:0.1em; padding-bottom:6px; border-bottom:2px solid #4A9DBF; flex-shrink:0; }
.tmg-card           { flex:1; background:#fff; border:1px solid #e8e0d8; border-radius:8px; padding:11px 13px; display:flex; flex-direction:column; min-height:0; }
.tmg-tag            { font-size:10px; font-weight:700; color:#c2410c; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:4px; flex-shrink:0; }
.tmg-title          { font-family:'DM Sans',sans-serif; font-size:13px; font-weight:700; color:#1c1917; line-height:1.35; margin-bottom:6px; flex-shrink:0; }
.tmg-ul             { padding-left:14px; margin:0; }
.tmg-li             { font-size:12px; color:#57534e; line-height:1.45; margin-bottom:3px; }
.tmg-li:last-child  { margin-bottom:0; }
