/* ═══════════════════════════════════════════════════════════════
   KASE — Kumar's AI Slide Editor
   Shared styles for all slide templates
   Add new template sections below as slides are converted
   ═══════════════════════════════════════════════════════════════ */

/* ── BASE ── */
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: #e8e0d8;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── SHARED SLIDE SHELL ── */
.slide {
  width: 1280px;
  height: 720px;
  border-radius: 16px;
  overflow: hidden;
  position: relative;
}
/* Dark or full-bleed coloured slides must set border-radius: 0 to prevent
   the body background (#e8e0d8) bleeding through the rounded corners */
.slide-full-bleed { border-radius: 0; }

/* ── SHARED CONTENT SLIDE BASE ──
   All light-background slides with an eyebrow + headline use this.
   Guarantees eyebrow and headline start at exactly the same position
   on every slide. Never override padding-top on individual templates. */
.content-slide {
  background: #fffbf7;
  display: flex;
  flex-direction: column;
  padding: 40px 60px 0 60px;
}

/* ── SHARED BOTTOM BAR ── */
.bottom-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0 16px;
  flex-shrink: 0;
  margin-top: auto;
}

.logo-block { display: flex; flex-direction: column; gap: 4px; }
.logo-block img { height: 16px; width: auto; display: block; }
.confidential { font-size: 9px; color: #a8a29e; letter-spacing: 0.04em; }

/* ── SHARED EYEBROW ── */
.eyebrow {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #c2410c;
  margin-bottom: 8px;
  flex-shrink: 0;
}

/* ── SHARED HEADLINE ── */
.headline {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 32px;
  font-weight: 400;
  line-height: 1.25;
  color: #1c1917;
  letter-spacing: -0.02em;
  flex-shrink: 0;
}

.headline .brand { color: #c2410c; }

/* ── SHARED TAKEAWAY BOX ── */
.takeaway-box {
  padding: 14px 40px;
  background: #1c1917;
  border-radius: 10px;
  text-align: center;
  flex-shrink: 0;
}

.takeaway-box p {
  font-size: 15px;
  font-weight: 500;
  color: #ffffff;
  line-height: 1.4;
}

.takeaway-box .accent { color: #c2410c; font-weight: 700; }

/* ── SHARED CARD HEADER ── */
/* Default: charcoal. Add a modifier class to override color.    */
.card-hdr           { padding:15px 20px; text-align:center; background:#1c1917; }
.card-hdr--navy     { background:#1e3a8a; }
.card-hdr--teal     { background:#0f766e; }
.card-hdr--blue     { background:#1e40af; }
.card-hdr--amber    { background:#b45309; }
.card-hdr-title     { font-family:'DM Sans',sans-serif; font-size:16px; font-weight:700; color:#fff; margin:0; line-height:1.3; }
.card-hdr-sub       { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400; color:rgba(255,255,255,0.88); margin:5px 0 0; line-height:1.3; }

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: COVER (F1)
   ═══════════════════════════════════════════════════════════════ */
.cover-slide {
  background: #fffbf7;
  display: grid;
  grid-template-columns: 1fr 600px;
}

.cover-slide .left {
  display: flex;
  flex-direction: column;
  padding: 52px 44px 44px 60px;
}

.cover-slide .logo-row {
  display: flex;
  align-items: center;
  gap: 28px;
  margin-bottom: auto;
}

.cover-slide .logo-divider {
  width: 1px;
  height: 38px;
  background: #d6cfc8;
}

.cover-slide .client-logo-placeholder {
  height: 32px;
  display: flex;
  align-items: center;
}

.cover-slide .client-logo-placeholder.empty {
  padding: 0 20px;
  border: 1.5px dashed #d6b99a;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 600;
  color: #a8a29e;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.cover-slide .content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 32px 0;
}

.cover-slide .headline {
  font-size: 50px;
  line-height: 1.1;
  margin-bottom: 28px;
}

.cover-slide .divider-line {
  width: 48px;
  height: 2px;
  background: #c2410c;
  margin-bottom: 20px;
  border-radius: 2px;
}

.cover-slide .tagline-prefix {
  font-size: 15px;
  font-weight: 400;
  color: #a8a29e;
  margin-bottom: 6px;
  letter-spacing: 0.01em;
}

.cover-slide .tagline-highlight {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 26px;
  font-weight: 400;
  line-height: 1.15;
  color: #c2410c;
  letter-spacing: -0.01em;
  white-space: nowrap;
}

.cover-slide .bottom-row {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-top: auto;
}

.cover-slide .date-badge {
  display: inline-flex;
  align-items: center;
  background: #1c1917;
  color: #ffffff;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 9px 22px;
  border-radius: 100px;
  white-space: nowrap;
}

.cover-slide .trust-badges {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-left: 8px;
}

.cover-slide .trust-badge-time {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2px;
}

.cover-slide .trust-badge-time img { height: 26px; width: auto; }

.cover-slide .trust-badge-time span {
  font-size: 10px;
  font-weight: 500;
  color: #78716c;
  letter-spacing: 0.03em;
}

.cover-slide .trust-separator { width: 1px; height: 32px; background: #e7dfd7; }
.cover-slide .trust-badge-gsv img { height: 40px; width: auto; }

.cover-slide .confidential-cover {
  position: absolute;
  bottom: 28px;
  right: 100px;
  font-size: 9px;
  color: #a8a29e;
  letter-spacing: 0.04em;
}

.cover-slide .right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 12px 12px 0;
}

.cover-slide .cover-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
}

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: COVER DARK
   ═══════════════════════════════════════════════════════════════ */
.cover-slide-dark {
