  display: inline-flex;
  align-items: center;
  gap: 28px;
  align-self: flex-start;
  background: #fffbf7;
  padding: 10px 20px;
  border-radius: 10px;
  margin-bottom: auto;
}

.cover-slide-dark .logo-divider {
  width: 1px;
  height: 38px;
  background: #d6cfc8;
}

.cover-slide-dark .client-logo-placeholder {
  height: 32px;
  display: flex;
  align-items: center;
}

.cover-slide-dark .client-logo-placeholder.empty {
  padding: 0 20px;
  border: 1.5px dashed #d6b99a;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 600;
  color: #a8a29e;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.cover-slide-dark .content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 32px 0;
}

.cover-slide-dark .headline {
  font-size: 50px;
  line-height: 1.1;
  margin-bottom: 28px;
  color: #e7e5e4;
}

.cover-slide-dark .divider-line {
  width: 48px;
  height: 2px;
  background: #c2410c;
  margin-bottom: 20px;
  border-radius: 2px;
}

.cover-slide-dark .tagline-prefix {
  font-size: 15px;
  font-weight: 400;
  color: #57534e;
  margin-bottom: 6px;
  letter-spacing: 0.01em;
}

.cover-slide-dark .tagline-highlight {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 26px;
  font-weight: 400;
  line-height: 1.15;
  color: #c2410c;
  letter-spacing: -0.01em;
}

.cover-slide-dark .bottom-row {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.cover-slide-dark .date-badge {
  display: inline-flex;
  align-items: center;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.25);
  color: #e7e5e4;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 9px 22px;
  border-radius: 100px;
  white-space: nowrap;
}

.cover-slide-dark .right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 12px 12px 0;
}

.cover-slide-dark .cover-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
}

.cover-slide-dark .confidential-cover {
  position: absolute;
  bottom: 28px;
  right: 100px;
  font-size: 9px;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.04em;
}

/* ═══════════════════════════════════════════════════════════════
   TEMPLATE: SECTION DIVIDER (D1)
   ═══════════════════════════════════════════════════════════════ */
.divider-slide {
  background: #fffbf7;
  display: grid;
  grid-template-columns: 1fr 600px;
}

.divider-slide .left {
  display: flex;
  flex-direction: column;
  padding: 52px 44px 52px 60px;
}

.divider-slide .logo-mark { margin-bottom: auto; }

.divider-slide .content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 32px 0;
}

.divider-slide .section-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #c2410c;
  margin-bottom: 16px;
}

.divider-slide .divider-line {
  width: 48px;
  height: 2px;
  background: #c2410c;
  margin-bottom: 24px;
  border-radius: 2px;
}

.divider-slide .headline {
  font-size: 54px;
  margin-bottom: 0;
}

.divider-slide .subtext {
  margin-top: 20px;
  font-size: 16px;
  font-weight: 400;
  color: #78716c;
  line-height: 1.45;
}

.divider-slide .right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 12px 12px 0;
}

.divider-slide .cover-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
}

.divider-slide .confidential-cover {
  position: absolute;
  bottom: 28px;
  right: 100px;
  font-size: 9px;
  color: #a8a29e;
  letter-spacing: 0.04em;
}

